//====================================================================
// SHARED MATH UTILITIES (Sprint 2.3 - Tier 1)
//====================================================================

safeDivide(float numerator, float denominator, float fallbackValue = na) =>
    float result = fallbackValue

    if not na(denominator) and denominator != 0
        result := numerator / denominator

    result

deriveDistance(float priceA, float priceB) =>
    math.abs(priceA - priceB)

deriveBarsElapsed(int barA, int barB) =>
    math.abs(barA - barB)

deriveVelocity(float distance, int barsElapsed) =>
    safeDivide(distance, barsElapsed)

deriveBodyDominanceRatio(float bodyLength, float candleRange) =>
    safeDivide(bodyLength, candleRange)

deriveWickRejectionRatio(float extremeWick, float candleRange) =>
    safeDivide(extremeWick, candleRange)

pricesAreEqual(float priceA, float priceB, float tolerance) =>
    math.abs(priceA - priceB) < tolerance

