// Session Level Data — tracks a single high/low level for a specific session
type SessionLevelData
    float highPrice
    int   highBar
    float lowPrice
    int   lowBar
    bool  isActive
    line  highLine
    line  lowLine
    label highLabel
    label lowLabel

