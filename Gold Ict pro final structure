//====================================================================
// SHARED MATH UTILITIES (Sprint 2.3 - Tier 1)
//====================================================================

safeDivide(float numerator, float denominator, float fallbackValue = na) =>
    float result = fallbackValue

    if not na(denominator) and denominator != 0
        result := numerator / denominator

    result

deriveDistance(float priceA, float priceB) =>
    math.abs(priceA - priceB)

deriveBarsElapsed(int barA, int barB) =>
    math.abs(barA - barB)

deriveVelocity(float distance, int barsElapsed) =>
    safeDivide(distance, barsElapsed)

deriveBodyDominanceRatio(float bodyLength, float candleRange) =>
    safeDivide(bodyLength, candleRange)

deriveWickRejectionRatio(float extremeWick, float candleRange) =>
    safeDivide(extremeWick, candleRange)

pricesAreEqual(float priceA, float priceB, float tolerance) =>
    math.abs(priceA - priceB) < tolerance

//====================================================================
// CANDIDATE ENGINE
//====================================================================

candidateHighPrice = ta.pivothigh(high, pivotLeftBars, pivotRightBars)
candidateLowPrice = ta.pivotlow(low, pivotLeftBars, pivotRightBars)

hasCandidateHigh = not na(candidateHighPrice)
hasCandidateLow = not na(candidateLowPrice)

candidateHighBar = bar_index - pivotRightBars
candidateLowBar = bar_index - pivotRightBars

//====================================================================
// ADAPTIVE THRESHOLD ENGINE (Sprint 2.2)
//====================================================================

currentATR = ta.atr(atrLength)

// Formation-snapshot historical reads (CW10003 fix — see captureFormationSnapshot()
// below). These use the fixed pivotRightBars offset and must be evaluated
// unconditionally on every bar, at global scope, rather than inside a
// conditionally-called function, per Pine's history-referencing execution
// model. Values are identical to what the old in-function high[pivotRightBars]
// (etc.) reads produced — this only changes *where* the read happens, not
// what it computes, so formation-snapshot values are unaffected.
formationPivotHigh = high[pivotRightBars]
formationPivotLow = low[pivotRightBars]
formationPivotOpen = open[pivotRightBars]
formationPivotClose = close[pivotRightBars]
formationPivotATR = currentATR[pivotRightBars]

