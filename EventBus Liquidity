    // ===============================
    if candidatesThisBarCount > 0
        resultsSize = array.size(replacementResults)
        if resultsSize > 0 and resultsSize == candidatesThisBarCount
            for i = 0 to resultsSize - 1
                if i >= 0 and i < resultsSize and i < candidatesThisBarCount
                    result = array.get(replacementResults, i)
                    
                    if result.accept
                        cand = array.get(g_swingCandidatesThisBar, i)
                        
                        // If decision is 'replaced', find and remove the conflicting pool from registry
                        if result.decision == ReplacementDecision.replaced and result.conflictPoolID != -1
                            regSize = array.size(g_registry)
                            if regSize > 0
                                for j = 0 to regSize - 1
                                    pool = array.get(g_registry, j)
                                    if pool.poolID == result.conflictPoolID
                                        array.remove(g_registry, j)
                                        break
                        
                        // 1. Read current poolID
                        currentPoolID = g_nextPoolID
                        // 2. Convert candidate to LiquidityPool (pure function, no globals)
                        pool = f_convertToLiquidityPool(cand, currentPoolID)
                        // 3. Push into Registry
                        array.push(g_registry, pool)
                        // 4. Increment pool ID counter
                        g_nextPoolID := g_nextPoolID + 1
    
    // ===============================
    // LIFECYCLE MANAGER — TOP-LEVEL
    // Process state transitions for all pools
    // ===============================
    lifecycle_processAllPools()
    
    // ===============================
    // REINFORCEMENT ENGINE — TOP-LEVEL ORCHESTRATION
    // 1. Call pure detection function (no globals modified inside)
    // 2. Apply returned events to registry and update global counters
    // ===============================
    reinforcementEvents = reinforcement_detectRevisits()
    
    eventsSize = array.size(reinforcementEvents)
    if eventsSize > 0
        for i = 0 to eventsSize - 1
            if i >= 0 and i < eventsSize
                event = array.get(reinforcementEvents, i)
                
                // Apply event to registry pool
                if event.poolIndex >= 0 and event.poolIndex < array.size(g_registry)
                    pool = array.get(g_registry, event.poolIndex)
                    pool.reinforcementCount := event.newReinforcementCount
                    pool.confidence := event.newConfidence
                    pool.state := event.newState
                    array.set(g_registry, event.poolIndex, pool)
                    
                    // Update global counters (TOP-LEVEL ONLY)
                    g_totalReinforcements := g_totalReinforcements + 1
                    if event.isNewlyReinforced
                        g_reinforcedPools := g_reinforcedPools + 1
    
    // ===============================
    // LIQUIDITY SWEEP ENGINE — TOP-LEVEL ORCHESTRATION
    // 1. Call pure processing function (no globals modified inside)
    // 2. Apply returned events to registry and update global counters
    // ===============================
    sweepEvents = sweep_processPools()
    
    sweepEventsSize = array.size(sweepEvents)
    if sweepEventsSize > 0
        for i = 0 to sweepEventsSize - 1
            if i >= 0 and i < sweepEventsSize
                event = array.get(sweepEvents, i)
                
                // Mark pool with sweep data (pure function returns updated pool object)
                updatedPool = sweep_markPool(event)
                if not na(updatedPool)
                    // Apply updated pool back to registry
                    array.set(g_registry, event.poolIndex, updatedPool)
                    
                    // Update global counters (TOP-LEVEL ONLY)
                    g_totalSweeps := g_totalSweeps + 1
                    if updatedPool.sweepCount == 1
                        g_sweptPools := g_sweptPools + 1
                    
                    if event.isBullish
                        g_bullishSweeps := g_bullishSweeps + 1
                    else
                        g_bearishSweeps := g_bearishSweeps + 1
    
    // ===============================
    // SESSION VISUALIZATION — TOP-LEVEL ONLY
    // Draw session lines. The draw function updates lines/labels in-place, so we reassign back to globals.
    // ===============================
    g_asianSession := viz_renderSessionLine(g_asianSession, i_colorAsian, "A", i_showAsian)
    g_londonSession := viz_renderSessionLine(g_londonSession, i_colorLondon, "L", i_showLondon)
    g_newYorkSession := viz_renderSessionLine(g_newYorkSession, i_colorNewYork, "NY", i_showNewYork)
    g_prevDaySession := viz_renderSessionLine(g_prevDaySession, i_colorPrevDay, "PD", i_showPrevDay)
    g_prevWeekSession := viz_renderSessionLine(g_prevWeekSession, i_colorPrevWeek, "PW", i_showPrevWeek)
    
    // ===============================
    // EVENT BUS — TOP-LEVEL ORCHESTRATION
    // 1. Capture events from other engines and publish them to the Event Bus
    // 2. Process the queue to mark events as consumed
    // 3. Update global event queue and counters
    // ===============================
    if i_enableEventBus
        // Publish Pool Created events
        if candidatesThisBarCount > 0
            resultsSize = array.size(replacementResults)
            if resultsSize > 0 and resultsSize == candidatesThisBarCount
                for i = 0 to resultsSize - 1
                    if i >= 0 and i < resultsSize and i < candidatesThisBarCount
                        result = array.get(replacementResults, i)
                        if result.accept
                            cand = array.get(g_swingCandidatesThisBar, i)
                            dirStr = cand.isResistanceSide ? "Bearish" : "Bullish"
                            ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.pool_created, g_nextPoolID, "", cand.priceLevel, dirStr, 0.0, "Pool Created: " + str.tostring(cand.poolType))
                            g_eventQueue := ebResult.updatedQueue
                            g_nextEventID := g_nextEventID + 1
                            g_eventsPublished := g_eventsPublished + 1
        
        // Publish Pool Reinforced events
        if eventsSize > 0
            for i = 0 to eventsSize - 1
                if i >= 0 and i < eventsSize
                    rEvent = array.get(reinforcementEvents, i)
                    if rEvent.poolIndex >= 0 and rEvent.poolIndex < array.size(g_registry)
                        rPool = array.get(g_registry, rEvent.poolIndex)
                        dirStr = rPool.isResistanceSide ? "Bearish" : "Bullish"
                        ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.pool_reinforced, rPool.poolID, "", rPool.priceLevel, dirStr, rEvent.newConfidence, "Pool Reinforced: ID " + str.tostring(rPool.poolID))
                        g_eventQueue := ebResult.updatedQueue
                        g_nextEventID := g_nextEventID + 1
                        g_eventsPublished := g_eventsPublished + 1
        
        // Publish Pool Swept events
        if sweepEventsSize > 0
            for i = 0 to sweepEventsSize - 1
                if i >= 0 and i < sweepEventsSize
                    sEvent = array.get(sweepEvents, i)
                    if sEvent.poolIndex >= 0 and sEvent.poolIndex < array.size(g_registry)
                        sPool = array.get(g_registry, sEvent.poolIndex)
                        dirStr = sEvent.isBullish ? "Bullish" : "Bearish"
                        ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.pool_swept, sPool.poolID, "", sEvent.sweepWickPrice, dirStr, sPool.confidence, "Pool Swept: ID " + str.tostring(sPool.poolID))
                        g_eventQueue := ebResult.updatedQueue
                        g_nextEventID := g_nextEventID + 1
                        g_eventsPublished := g_eventsPublished + 1
        
        // Publish Session Started events
        if g_currentSessionName != "None"
            // Check for Asian session start
            if g_currentSessionName == "Asian" and g_asianSession.isActive and (na(g_asianSession.highPrice) or (g_asianSession.highBar == bar_index))
                ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.session_started, 0, "Asian", close, "Neutral", 0.0, "Session Started: Asian")
                g_eventQueue := ebResult.updatedQueue
                g_nextEventID := g_nextEventID + 1
                g_eventsPublished := g_eventsPublished + 1
            // Check for London session start
            else if g_currentSessionName == "London" and g_londonSession.isActive and (na(g_londonSession.highPrice) or (g_londonSession.highBar == bar_index))
                ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.session_started, 0, "London", close, "Neutral", 0.0, "Session Started: London")
                g_eventQueue := ebResult.updatedQueue
                g_nextEventID := g_nextEventID + 1
                g_eventsPublished := g_eventsPublished + 1
            // Check for New York session start
            else if g_currentSessionName == "New York" and g_newYorkSession.isActive and (na(g_newYorkSession.highPrice) or (g_newYorkSession.highBar == bar_index))
                ebResult = event_publish(g_eventQueue, g_nextEventID, EventType.session_started, 0, "New York", close, "Neutral", 0.0, "Session Started: New York")
                g_eventQueue := ebResult.updatedQueue
                g_nextEventID := g_nextEventID + 1
                g_eventsPublished := g_eventsPublished + 1
        
        // Process the event queue (mark all unprocessed as processed)
        ebResult = event_process(g_eventQueue)
        g_eventQueue := ebResult.updatedQueue
        g_eventsProcessedCount := g_eventsProcessedCount + ebResult.totalProcessed
    
    // Visualize output
    viz_renderPivots(ctx)
    viz_renderSwingLines()
    viz_renderSweeps(sweepEvents)
    
    // Clear this-bar candidates for next bar
    array.clear(g_swingCandidatesThisBar)

