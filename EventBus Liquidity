// Reinforcement event result — returned by pure Reinforcement Engine functions
type ReinforcementEvent
    int     poolIndex          // Index of reinforced pool in registry
    bool    isNewlyReinforced  // true if this is the pool's first reinforcement
    int     newReinforcementCount // Updated reinforcement count
    float   newConfidence      // Updated confidence score
    PoolState newState         // Updated pool state

