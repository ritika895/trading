// =========================================================================
f_validate_pool_structure(LiquidityPool pool, int poolId, int direction, ContextSnapshot snapshot) =>
    bool isValid = false
    string status = "INVALID"
    string reason = "UNKNOWN"
    
    if not snapshot.integrityFlag
        reason := "Snapshot integrity failed"
        status := "FAILED_SNAPSHOT"
    else if poolId == -1 or na(pool)
        reason := "No pool selected"
        status := "NO_POOL"
    else if pool.state == LifecycleState.INVALIDATED
        reason := "Pool is invalidated"
        status := "INVALIDATED"
    else if pool.state == LifecycleState.EXPIRED
        reason := "Pool is expired"
        status := "EXPIRED"
    else if pool.state == LifecycleState.FORMED or pool.state == LifecycleState.ACTIVE or pool.state == LifecycleState.REINFORCED or pool.state == LifecycleState.SWEPT
        isValid := true
        status  := "VALID"
        reason  := "Structure intact"
    else
        reason := "Ineligible state"
        status := "INELIGIBLE"
        
    StructuralValidationResult.new(
        poolId                = poolId,
        direction             = direction,
        isStructurallyValid   = isValid,
        validationStatus      = status,
        validationReason      = reason,
        integrityFlag         = true,
        contextReference      = snapshot
    )

f_execute_structural_validation(ContextSnapshot snapshot) =>
    StructuralValidationResult bullVal = f_validate_pool_structure(snapshot.selectionResult.bullishRank1, snapshot.selectionResult.bestBullishId, 1, snapshot)
    StructuralValidationResult bearVal = f_validate_pool_structure(snapshot.selectionResult.bearishRank1, snapshot.selectionResult.bestBearishId, -1, snapshot)
    StructuralValidationResult overallVal = f_validate_pool_structure(snapshot.selectionResult.overallBest, snapshot.selectionResult.bestOverallId, 0, snapshot)
    
    int validCount = 0
    int invalidCount = 0
    if bullVal.isStructurallyValid
        validCount += 1
    else
        invalidCount += 1
    if bearVal.isStructurallyValid
        validCount += 1
    else
        invalidCount += 1
    if overallVal.isStructurallyValid
        validCount += 1
    else
        invalidCount += 1
        
    StructuralValidationSet.new(
        bullishValidation  = bullVal,
        bearishValidation  = bearVal,
        overallValidation  = overallVal,
        executedCount      = 3,
        validCount         = validCount,
        invalidCount       = invalidCount,
        pipelineIntegrity  = true
    )

// =========================================================================
// PHASE 6.3: ENTRY ENGINE - LIQUIDITY SWEEP CONFIRMATION
// =========================================================================
f_validate_sweep(StructuralValidationResult structVal) =>
    bool isConfirmed = false
    string status = "PENDING"
    string reason = "UNKNOWN"
    
    if not structVal.integrityFlag
        reason := "Structural validation integrity failed"
        status := "FAILED_STRUCT"
    else if not structVal.isStructurallyValid
        reason := "Pool is not structurally valid"
        status := "STRUCT_INVALID"
    else
        LiquidityPool pool = na
        if structVal.direction == 1
            pool := structVal.contextReference.selectionResult.bullishRank1
        else if structVal.direction == -1
            pool := structVal.contextReference.selectionResult.bearishRank1
        else if structVal.direction == 0
            pool := structVal.contextReference.selectionResult.overallBest
            
        if na(pool)
            reason := "Pool reference missing"
            status := "MISSING_POOL"
        else if pool.isSwept
            isConfirmed := true
            status := "CONFIRMED"
            reason := "Liquidity sweep confirmed"
        else
            reason := "Awaiting liquidity sweep"
            status := "AWAITING_SWEEP"
            
    SweepValidationResult.new(
        poolId              = structVal.poolId,
        direction           = structVal.direction,
        isSweepConfirmed    = isConfirmed,
        sweepStatus         = status,
        sweepReason         = reason,
        integrityFlag       = true,
        structuralReference = structVal
    )

f_execute_sweep_validation(StructuralValidationSet structSet) =>
    SweepValidationResult bullSweep = f_validate_sweep(structSet.bullishValidation)
    SweepValidationResult bearSweep = f_validate_sweep(structSet.bearishValidation)
    SweepValidationResult overallSweep = f_validate_sweep(structSet.overallValidation)
    
    int confirmedCount = 0
    int rejectedCount = 0
    if bullSweep.isSweepConfirmed
        confirmedCount += 1
    else
        rejectedCount += 1
    if bearSweep.isSweepConfirmed
        confirmedCount += 1
    else
        rejectedCount += 1
    if overallSweep.isSweepConfirmed
        confirmedCount += 1
    else
        rejectedCount += 1
        
    SweepValidationSet.new(
        bullishSweep      = bullSweep,
        bearishSweep      = bearSweep,
        overallSweep      = overallSweep,
        executedCount     = 3,
        confirmedCount    = confirmedCount,
        rejectedCount     = rejectedCount,
        pipelineIntegrity = true
    )

// =========================================================================
// PHASE 6.4: ENTRY ENGINE - MARKET CONTEXT VALIDATION
// =========================================================================
f_validate_market_context(SweepValidationResult sweepVal) =>
    bool isContextValid = false
    bool isSessionValid = false
    bool isTrendValid = true      
    bool isStructureValid = true  
    string reason = "UNKNOWN"
    
    if not sweepVal.integrityFlag
        reason := "Sweep validation integrity failed"
    else if not sweepVal.isSweepConfirmed
        reason := "Sweep not confirmed"
    else
        SessionType sess = sweepVal.structuralReference.contextReference.currentSession
        
        if sess == SessionType.NONE
            isSessionValid := false
            reason := "Invalid session (None)"
        else
            isSessionValid := true
            reason := "Session valid"
            
        isContextValid := isSessionValid and isTrendValid and isStructureValid
        
        if isContextValid
            reason := "Context fully valid"
            
    MarketContextResult.new(
        poolId              = sweepVal.poolId,
        direction           = sweepVal.direction,
        contextValid        = isContextValid,
        sessionValid        = isSessionValid,
        trendValid          = isTrendValid,
        structureValid      = isStructureValid,
        contextReason       = reason,
        integrityFlag       = true,
        sweepReference      = sweepVal
    )

f_execute_context_validation(SweepValidationSet sweepSet) =>
    MarketContextResult bullCtx = f_validate_market_context(sweepSet.bullishSweep)
    MarketContextResult bearCtx = f_validate_market_context(sweepSet.bearishSweep)
    MarketContextResult overallCtx = f_validate_market_context(sweepSet.overallSweep)
    
    int passedCount = 0
    int failedCount = 0
    if bullCtx.contextValid
        passedCount += 1
    else
        failedCount += 1
    if bearCtx.contextValid
        passedCount += 1
    else
        failedCount += 1
    if overallCtx.contextValid
        passedCount += 1
    else
        failedCount += 1
        
    MarketContextSet.new(
        bullishContext     = bullCtx,
        bearishContext     = bearCtx,
        overallContext     = overallCtx,
        executedCount      = 3,
        passedCount        = passedCount,
        failedCount        = failedCount,
        pipelineIntegrity  = true
    )

