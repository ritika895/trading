var ReplacementConfig global_replacement_config = ReplacementConfig.new(
    replacementTolerance   = 0.0,
    enableReplacement      = true,
    enableMerge            = true,
    keepHighestConfidence  = true,
    keepNewestPool         = false
)

f_create_replacement_result(ReplacementDecision decision, int existingIdx, int newIdx, string reason, bool success) =>
    ReplacementResult.new(
        decision            = decision,
        existingPoolIndex   = existingIdx,
        newPoolIndex        = newIdx,
        replacementReason   = reason,
        success             = success
    )

replacement_hasConflict(LiquidityPool pool, float tolerance) =>
    bool found = false
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            if p.pType == pool.pType
                float dist = math.abs(p.price - pool.price)
                if dist <= tolerance
                    found := true
                    break
    found

replacement_findConflict(LiquidityPool pool, float tolerance) =>
    bool found = false
    int index = -1
    float distance = -1.0
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            if p.pType == pool.pType
                float dist = math.abs(p.price - pool.price)
                if dist <= tolerance
                    found := true
                    index := i
                    distance := dist
                    break
    [found, index, distance]

replacement_decideAction(LiquidityPool newPool, LiquidityPool existingPool, bool hasConflict, ReplacementConfig config) =>
    ReplacementDecision decision = ReplacementDecision.NO_CONFLICT
    if not hasConflict
        decision := ReplacementDecision.NO_CONFLICT
    else if not config.enableReplacement
        decision := ReplacementDecision.KEEP_EXISTING
    else if newPool.confidence < 30.0
        decision := ReplacementDecision.IGNORE_NEW
    else if existingPool.confidence > newPool.confidence
        decision := ReplacementDecision.KEEP_EXISTING
    else if newPool.confidence > existingPool.confidence
        decision := ReplacementDecision.REPLACE_EXISTING
    else if config.enableMerge and newPool.pType == existingPool.pType
        decision := ReplacementDecision.MERGE
    else
        decision := ReplacementDecision.KEEP_EXISTING
    decision

// =========================================================================
// PHASE 5.1: POOL SELECTION ENGINE - ELIGIBILITY FILTERING
// =========================================================================
f_filter_eligible_pools() =>
    EligibilityResult result = EligibilityResult.new(
        eligiblePools         = array.new<LiquidityPool>(0),
        eligibleBullishCount  = 0,
        eligibleBearishCount  = 0,
        integrityFlag         = true
    )
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            if p.state == LifecycleState.ACTIVE or p.state == LifecycleState.REINFORCED or p.state == LifecycleState.SWEPT
                array.push(result.eligiblePools, p)
                if p.pType == PoolType.BULLISH
                    result.eligibleBullishCount += 1
                else if p.pType == PoolType.BEARISH
                    result.eligibleBearishCount += 1
    if result.eligibleBullishCount + result.eligibleBearishCount != array.size(result.eligiblePools)
        result.integrityFlag := false
    result

// =========================================================================
// PHASE 5.2: POOL SELECTION ENGINE - SCORING ENGINE
// =========================================================================
f_calculate_scores(EligibilityResult eligibility) =>
    ScoringResult result = ScoringResult.new(
        scores        = array.new<PoolScore>(0),
        highestScore  = 0.0,
        lowestScore   = 0.0,
        avgScore      = 0.0,
        scoredCount   = 0
    )
    float sumScores = 0.0
    float currentAtr = ta.atr(14)
    if na(currentAtr)
        currentAtr := 1.0
    SessionType currentSession = f_get_session_type()
    
    if array.size(eligibility.eligiblePools) > 0
        for i = 0 to array.size(eligibility.eligiblePools) - 1
            LiquidityPool p = array.get(eligibility.eligiblePools, i)
            float rawScore = p.confidence
            rawScore += p.touchCount * 10.0
            if p.state == LifecycleState.REINFORCED
                rawScore += 15.0
            else if p.state == LifecycleState.ACTIVE
                rawScore += 10.0
            else if p.state == LifecycleState.SWEPT
                rawScore -= 10.0
            if p.sessionCreated == currentSession
                rawScore += 5.0
            float dist = math.abs(close - p.price)
            float distFactor = 0.0
            if currentAtr > 0
                distFactor := math.max(0.0, 50.0 - (dist / currentAtr) * 10.0)
            rawScore += distFactor
            
            PoolScore ps = PoolScore.new(poolId = p.id, rawScore = rawScore, normalizedScore = 0.0)
            array.push(result.scores, ps)
            sumScores += rawScore
            if rawScore > result.highestScore
                result.highestScore := rawScore
            if rawScore < result.lowestScore or result.scoredCount == 0
                result.lowestScore := rawScore
            result.scoredCount += 1
            
    if result.scoredCount > 0
        result.avgScore := sumScores / result.scoredCount
    result

// =========================================================================
// PHASE 5.3: POOL SELECTION ENGINE - RANKING ENGINE
// =========================================================================
f_compare_pools(RankedPool a, RankedPool b) =>
    int res = 0
    if math.abs(a.score - b.score) < EPSILON
        if a.pool.confidence > b.pool.confidence
            res := 1
        else if a.pool.confidence < b.pool.confidence
            res := -1
        else
            if a.pool.touchCount > b.pool.touchCount
                res := 1
            else if a.pool.touchCount < b.pool.touchCount
                res := -1
            else
                if a.pool.barCreated > b.pool.barCreated
                    res := 1
                else if a.pool.barCreated < b.pool.barCreated
                    res := -1
                else
                    float distA = math.abs(close - a.pool.price)
                    float distB = math.abs(close - b.pool.price)
                    if distA < distB
                        res := 1
                    else if distA > distB
                        res := -1
                    else
                        if a.pool.id < b.pool.id
                            res := 1
                        else if a.pool.id > b.pool.id
                            res := -1
    else if a.score > b.score
        res := 1
    else
        res := -1
    res

f_rank_pools(EligibilityResult eligibility, ScoringResult scoring) =>
    RankingResult result = RankingResult.new(
        rankedBullish       = array.new<LiquidityPool>(0),
        rankedBearish       = array.new<LiquidityPool>(0),
        rankedOverall       = array.new<LiquidityPool>(0),
        highestScore        = 0.0,
        lowestScore         = 0.0,
        rankedBullishCount  = 0,
        rankedBearishCount  = 0
    )
    RankedPool[] tempArr = array.new<RankedPool>(0)
    
    if array.size(eligibility.eligiblePools) > 0
        for i = 0 to array.size(eligibility.eligiblePools) - 1
            LiquidityPool p = array.get(eligibility.eligiblePools, i)
            float score = 0.0
            if array.size(scoring.scores) > 0
                for j = 0 to array.size(scoring.scores) - 1
                    PoolScore ps = array.get(scoring.scores, j)
                    if ps.poolId == p.id
                        score := ps.rawScore
                        break
            RankedPool rp = RankedPool.new(pool = p, score = score)
            array.push(tempArr, rp)
            
    if array.size(tempArr) > 1
        for i = 1 to array.size(tempArr) - 1
            RankedPool key = array.get(tempArr, i)
            int j = i - 1
            while j >= 0 and f_compare_pools(key, array.get(tempArr, j)) > 0
                array.set(tempArr, j + 1, array.get(tempArr, j))
                j := j - 1
            array.set(tempArr, j + 1, key)
            
    if array.size(tempArr) > 0
        for i = 0 to array.size(tempArr) - 1
            RankedPool rp = array.get(tempArr, i)
            array.push(result.rankedOverall, rp.pool)
            if rp.pool.pType == PoolType.BULLISH
                array.push(result.rankedBullish, rp.pool)
                result.rankedBullishCount += 1
            else if rp.pool.pType == PoolType.BEARISH
                array.push(result.rankedBearish, rp.pool)
                result.rankedBearishCount += 1
            if i == 0
                result.highestScore := rp.score
            if i == array.size(tempArr) - 1
                result.lowestScore := rp.score
    result

// =========================================================================
// PHASE 5.4: POOL SELECTION ENGINE - PRIORITY & SELECTION
// =========================================================================
f_classify_pool(float score, float max_score, float avg_score) =>
    PriorityClass pc = PriorityClass.BACKGROUND
    if max_score > 0
        float ratio = score / max_score
        if ratio >= 0.90
            pc := PriorityClass.CRITICAL
        else if ratio >= 0.75
            pc := PriorityClass.HIGH
        else if ratio >= 0.50
            pc := PriorityClass.MEDIUM
        else if ratio >= 0.25
            pc := PriorityClass.LOW
    pc

f_execute_selection(RankingResult ranking, ScoringResult scoring) =>
    SelectionResult result = SelectionResult.new(
        bestBullishId      = -1,
        bestBearishId      = -1,
        bestOverallId      = -1,
        bullishRank1       = na,
        bearishRank1       = na,
        overallBest        = na,
        highestPriority    = PriorityClass.BACKGROUND,
        integrityFlag      = true,
        stats              = SelectionStatistics.new(
            eligibleCount = 0, 
            rankedCount   = 0, 
            avgScore      = 0.0, 
            highestScore  = 0.0
        )
    )
    
    result.stats.eligibleCount := scoring.scoredCount
    result.stats.rankedCount   := array.size(ranking.rankedOverall)
    result.stats.avgScore      := scoring.avgScore
    result.stats.highestScore  := ranking.highestScore
    
    if array.size(ranking.rankedBullish) > 0
        LiquidityPool b = array.get(ranking.rankedBullish, 0)
        result.bullishRank1  := b
        result.bestBullishId := b.id
        
    if array.size(ranking.rankedBearish) > 0
        LiquidityPool b = array.get(ranking.rankedBearish, 0)
        result.bearishRank1  := b
        result.bestBearishId := b.id
        
    if array.size(ranking.rankedOverall) > 0
        LiquidityPool b = array.get(ranking.rankedOverall, 0)
        result.overallBest    := b
        result.bestOverallId  := b.id
        result.highestPriority := f_classify_pool(ranking.highestScore, ranking.highestScore, scoring.avgScore)
        
    if result.stats.rankedCount > 0 and result.bestOverallId == -1
        result.integrityFlag := false
    if result.bestOverallId != -1 and result.bestBullishId == -1 and result.bestBearishId == -1
        result.integrityFlag := false
        
    result

