            if array.size(reg) > 0
                for j = 0 to array.size(reg) - 1
                    StrategyMetadata m = array.get(reg, j)
                    if m.id == ctx.strategyId
                        isShadow := m.shadowMode
                        break
            
            bool approved = false
            string reason = "UNKNOWN"
            
            if not ctx.integrityFlag
                reason := "Context integrity failed"
                rejectedCount += 1
            else if isShadow
                reason := "Shadow mode active"
                shadowCount += 1
            else
                approved := true
                reason := "Dispatch approved"
                dispatchedCount += 1
                
                // Invoke Placeholder Strategy
