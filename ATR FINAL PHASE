databaseSize() =>
    array.size(swingIds)

swingIndexFromId(int swingId) =>
    int resultIndex = NO_INDEX
    int size = array.size(swingIds)

    if swingId > 0 and size > 0
        for index = 0 to size - 1
            int storedSwingId = array.get(swingIds, index)

            if resultIndex == NO_INDEX and storedSwingId == swingId
                resultIndex := index

    resultIndex

isValidSwingType(int swingType) =>
    swingType == SWING_HIGH or swingType == SWING_LOW

isValidSwingStatus(int statusValue) =>
    statusValue == STATUS_PENDING or statusValue == STATUS_CONFIRMED or statusValue == STATUS_REPLACED or statusValue == STATUS_REJECTED

// Reserved field validators (Sprint 2.1.5) - mirror the existing
// isValidSwingType / isValidSwingStatus pattern. These only validate
// that stored values are within the defined enum range; they do not
// introduce any new trading logic.
isValidStructureLabel(int structureLabel) =>
    structureLabel == STRUCTURE_NONE or structureLabel == STRUCTURE_HH or structureLabel == STRUCTURE_HL or structureLabel == STRUCTURE_LH or structureLabel == STRUCTURE_LL

isValidBreakType(int breakType) =>
    breakType == BREAK_NONE or breakType == BREAK_BOS or breakType == BREAK_CHOCH

isValidImportance(int importanceValue) =>
    importanceValue == IMPORTANCE_MINOR or importanceValue == IMPORTANCE_INTERMEDIATE or importanceValue == IMPORTANCE_MAJOR

debugAssert(bool condition, string message) =>
    if showDebugLabels and not condition
        runtime.error(message)

databaseHasDuplicateIds() =>
    bool hasDuplicate = false
    int size = array.size(swingIds)

    if size > 1
        for leftIndex = 0 to size - 2
            int leftId = array.get(swingIds, leftIndex)

            for rightIndex = leftIndex + 1 to size - 1
                int rightId = array.get(swingIds, rightIndex)

                if leftId == rightId
                    hasDuplicate := true

    hasDuplicate

databaseIsValid() =>
    int size = array.size(swingIds)
    int typesSize = array.size(swingTypes)
    int pricesSize = array.size(swingPrices)
    int barsSize = array.size(swingBars)
    int statusesSize = array.size(swingStatuses)
    int atrSize = array.size(swingATR)
    int legLengthSize = array.size(swingLegLength)
    int strengthSize = array.size(swingStrength)
    int scoreSize = array.size(swingScore)
    int liquiditySize = array.size(swingLiquidity)
    int sessionSize = array.size(swingSession)
    int trendSize = array.size(swingTrend)

    // Reserved field sizes (Sprint 2.1.5)
    int structureLabelSize = array.size(swingStructureLabel)
    int brokenBarSize = array.size(swingBrokenBar)
    int breakTypeSize = array.size(swingBreakType)
    int sweptStatusSize = array.size(swingSweptStatus)
    int sweptBarSize = array.size(swingSweptBar)
    int importanceSize = array.size(swingImportance)

    // Formation Snapshot field sizes (Sprint 2.3)
    int formationATRSize = array.size(swingFormationATR)
    int candleRangeSize = array.size(swingCandleRange)
    int candleBodySize = array.size(swingCandleBody)
    int candleExtremeWickSize = array.size(swingCandleExtremeWick)

    bool valid = true
    bool sizesMatch = typesSize == size and pricesSize == size and barsSize == size and statusesSize == size and atrSize == size and legLengthSize == size and strengthSize == size and scoreSize == size and liquiditySize == size and sessionSize == size and trendSize == size and structureLabelSize == size and brokenBarSize == size and breakTypeSize == size and sweptStatusSize == size and sweptBarSize == size and importanceSize == size and formationATRSize == size and candleRangeSize == size and candleBodySize == size and candleExtremeWickSize == size

    if not sizesMatch
        valid := false

    if databaseHasDuplicateIds()
        valid := false

    int previousConfirmedType = SWING_NONE

    if size > 0
        for index = 0 to size - 1
            int storedSwingId = array.get(swingIds, index)
            int storedSwingType = array.get(swingTypes, index)
            int storedStatus = array.get(swingStatuses, index)

            if storedSwingId <= 0
                valid := false

            if not isValidSwingType(storedSwingType)
                valid := false

            if not isValidSwingStatus(storedStatus)
                valid := false

            // Reserved field range validation (Sprint 2.1.5)
            int storedStructureLabel = array.get(swingStructureLabel, index)
            int storedBreakType = array.get(swingBreakType, index)
            int storedImportance = array.get(swingImportance, index)

            if not isValidStructureLabel(storedStructureLabel)
                valid := false

            if not isValidBreakType(storedBreakType)
                valid := false

            if not isValidImportance(storedImportance)
                valid := false

            if storedStatus == STATUS_CONFIRMED
                if previousConfirmedType == storedSwingType
                    valid := false

                previousConfirmedType := storedSwingType

    valid

validateDatabaseInDebug(string message) =>
    if showDebugLabels
        debugAssert(databaseIsValid(), message)

databaseLastSwing() =>
    int size = array.size(swingIds)
    bool exists = size > 0

    int storedSwingId = NO_SWING_ID
    int storedSwingType = SWING_NONE
    float storedSwingPrice = na
    int storedSwingBar = NO_INDEX
    int storedStatus = STATUS_REJECTED

    if exists
        int lastIndex = size - 1
        storedSwingId := array.get(swingIds, lastIndex)
        storedSwingType := array.get(swingTypes, lastIndex)
        storedSwingPrice := array.get(swingPrices, lastIndex)
        storedSwingBar := array.get(swingBars, lastIndex)
        storedStatus := array.get(swingStatuses, lastIndex)

    [storedSwingId, storedSwingType, storedSwingPrice, storedSwingBar, storedStatus, exists]

databaseLastConfirmedSwing() =>
    int confirmedSwingId = NO_SWING_ID
    int confirmedSwingType = SWING_NONE
    float confirmedSwingPrice = na
    int confirmedSwingBar = NO_INDEX
    bool exists = false

    int size = array.size(swingIds)

    if size > 0
        for offset = 0 to size - 1
            int index = size - 1 - offset
            int storedStatus = array.get(swingStatuses, index)

            if not exists and storedStatus == STATUS_CONFIRMED
                confirmedSwingId := array.get(swingIds, index)
                confirmedSwingType := array.get(swingTypes, index)
                confirmedSwingPrice := array.get(swingPrices, index)
                confirmedSwingBar := array.get(swingBars, index)
                exists := true

    [confirmedSwingId, confirmedSwingType, confirmedSwingPrice, confirmedSwingBar, exists]

pushReservedSwingFields() =>
    array.push(swingATR, na)
    array.push(swingLegLength, na)
    array.push(swingStrength, na)
    array.push(swingScore, na)
    array.push(swingLiquidity, na)
    array.push(swingSession, RESERVED_STRING_DEFAULT)
    array.push(swingTrend, RESERVED_INT_DEFAULT)

    // Reserved field defaults (Sprint 2.1.5)
    // These are structural placeholders only - no trading logic populates
    // them yet. Defaults are chosen to be unambiguous "not yet evaluated"
    // sentinels, consistent with NO_INDEX / RESERVED_INT_DEFAULT usage
    // elsewhere in the database.
    array.push(swingStructureLabel, STRUCTURE_NONE)
    array.push(swingBrokenBar, NO_INDEX)
    array.push(swingBreakType, BREAK_NONE)
    array.push(swingSweptStatus, false)
    array.push(swingSweptBar, NO_INDEX)
    array.push(swingImportance, IMPORTANCE_MINOR)

    // Formation Snapshot defaults (Sprint 2.3)
    // Overwritten immediately by captureFormationSnapshot() below; pushed
    // here only so every array stays size-parity-correct at every point,
    // consistent with how every other field in this function is defaulted.
    array.push(swingFormationATR, na)
    array.push(swingCandleRange, na)
    array.push(swingCandleBody, na)
    array.push(swingCandleExtremeWick, na)

// Formation Snapshot capture (Sprint 2.3)
// This is the ONLY approved extension point for formation-time metadata
// (Architectural Invariant 3). Called from createSwing() and
// replacePendingSwing() only. No other function may write these fields -
// deliberately no public setter accessors exist for them (see the
// read-only accessor pair further below), so this function is the sole
// write path by construction, not just by convention.
//
// Uses pivotRightBars - a "simple int" input, valid as a compile-time-
// known historical offset - to read the pivot candle's own OHLC and ATR.
// This is the same fixed-offset mechanism candidateHighBar/candidateLowBar
// already rely on, and is what avoids the variable-offset/max_bars_back
// problem ruled out during design review.
captureFormationSnapshot(int swingId) =>
    int swingIndex = swingIndexFromId(swingId)
    bool captured = swingIndex != NO_INDEX

    if captured
        int storedSwingType = array.get(swingTypes, swingIndex)

        float pivotHigh = high[pivotRightBars]
        float pivotLow = low[pivotRightBars]
        float pivotOpen = open[pivotRightBars]
        float pivotClose = close[pivotRightBars]
        float pivotATR = currentATR[pivotRightBars]

        float candleRange = pivotHigh - pivotLow
        float candleBody = math.abs(pivotClose - pivotOpen)
        float extremeWick = storedSwingType == SWING_HIGH ? pivotHigh - math.max(pivotOpen, pivotClose) : math.min(pivotOpen, pivotClose) - pivotLow

        array.set(swingFormationATR, swingIndex, pivotATR)
        array.set(swingCandleRange, swingIndex, candleRange)
        array.set(swingCandleBody, swingIndex, candleBody)
        array.set(swingCandleExtremeWick, swingIndex, extremeWick)

    captured

createSwing(int swingId, int swingType, float swingPrice, int swingBar) =>
    debugAssert(swingId > 0, "Swing ID must be positive.")
    debugAssert(isValidSwingType(swingType), "Invalid swing type.")

    array.push(swingIds, swingId)
    array.push(swingTypes, swingType)
    array.push(swingPrices, swingPrice)
    array.push(swingBars, swingBar)
    array.push(swingStatuses, STATUS_PENDING)
    pushReservedSwingFields()
    captureFormationSnapshot(swingId)

    swingId

