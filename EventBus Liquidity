    EventType eventType      // Type of the event
    int       poolID         // Optional: associated pool ID (0 if not applicable)
    string    sessionID      // Optional: associated session ID ("" if not applicable)
    int       eventTime      // Bar index when the event occurred
    float     price          // Price associated with the event
