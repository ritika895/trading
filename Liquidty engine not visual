// -----------------------------------------------------------------------------
// newState
// Creates and returns a brand-new, empty LiquidityEngineState. The calling
// script must hold the result in its OWN `var` so it persists across bars:
//
//     var state = LiquidityEngineLib.newState()
//
// Every other exported function below takes such a state as its first
// argument. A script may call newState() more than once to run several
// fully independent liquidity engines side by side (e.g. per symbol, per
// timeframe, or per policy configuration) — each with its own registry,
// event log, and id counters.
// -----------------------------------------------------------------------------
export newState() =>
    LiquidityEngineState.new(
         registry          = array.new<LiquidityObject>(),
         idIndexMap        = map.new<int, int>(),
         liveIds           = array.new<int>(),
         equalLevelRefMap  = map.new<int, int>(),
         eventLog          = array.new<LiquidityEvent>(),
         nextObjectId      = 0,
         nextEventId       = 0)

// -----------------------------------------------------------------------------
// submitSwingFact
// Submits a confirmed swing-point fact from Structure Classification.
// Structure Classification must have already finalized and attached the
// trade-through-since-formation tag before calling this function — this
// module performs no independent check of that condition.
//
// Params:
//   state                    - the caller-owned LiquidityEngineState to mutate
//   orientation              - ORIENTATION_BUY_SIDE or ORIENTATION_SELL_SIDE
//   level                    - the confirmed swing price
//   toleranceOffset          - price-unit tolerance beyond level required to trigger a sweep
//   proximityBand            - price-unit band defining the Approached zone
//   stalenessBars            - bars after formation, untouched, before Invalidated/Stale (0 permitted)
//   reactionWindowBars       - externally supplied policy value (0 permitted; mechanism owned here, value owned upstream)
//   formationBar             - bar_index of confirmation
//   tradeThroughAtFormation  - finalized upstream fact: was the level already exceeded at confirmation
//   originRefId              - traceability reference to the originating swing fact
//
// Returns: the new liquidity object's id.
// -----------------------------------------------------------------------------
export submitSwingFact(LiquidityEngineState state, string orientation, float level, float toleranceOffset, float proximityBand, int stalenessBars, int reactionWindowBars, int formationBar, bool tradeThroughAtFormation, int originRefId) =>
    f_createObject(state, ORIGIN_SWING, orientation, level, toleranceOffset, proximityBand, stalenessBars, reactionWindowBars, formationBar, tradeThroughAtFormation, originRefId)

// -----------------------------------------------------------------------------
// submitEqualLevelFact
// Submits a confirmed Equal-High/Low cluster fact from Structure
// Classification. If `originRefId` already maps to an existing liquidity
// object AND that object is still live (not yet RESOLVED), the existing
// object's reinforcement count is incremented and a REINFORCED event is
// emitted (frozen spec section 14).
//
// PATCH (correctness): if the mapped object has already reached RESOLVED
// (e.g., it was swept, and a later fact reports another touch at the same
// originRefId — such as a retest after the sweep), it is NEVER mutated.
// Per the frozen architecture's rule that "a resolved object is never
// reused for new activity," a brand-new liquidity object is created for
// this new cluster occurrence, and the reference map is repointed to it.
// The original resolved object is left fully intact for historical query.
//
// Returns: the id of the (new or reinforced) liquidity object.
// -----------------------------------------------------------------------------
export submitEqualLevelFact(LiquidityEngineState state, string orientation, float level, float toleranceOffset, float proximityBand, int stalenessBars, int reactionWindowBars, int formationBar, bool tradeThroughAtFormation, int originRefId) =>
    int  resultId       = na
    bool reinforcedLive = false

    if map.contains(state.equalLevelRefMap, originRefId)
        int mappedId = map.get(state.equalLevelRefMap, originRefId)
        mappedObj = f_getObjectRef(state, mappedId)
        f_assert(not na(mappedObj), "equal-level ref map points to a missing object")
        if mappedObj.lifecycleState != STATE_RESOLVED
            mappedObj.reinforcementCount += 1
            f_emitEvent(state, EVT_REINFORCED, mappedId, formationBar, level, RES_NONE)
            resultId := mappedId
            reinforcedLive := true
        // else: mapped object is terminal — fall through to creation below.
        // The resolved object is NOT touched.

    if not reinforcedLive
        resultId := f_createObject(state, ORIGIN_EQUAL_LEVEL, orientation, level, toleranceOffset, proximityBand, stalenessBars, reactionWindowBars, formationBar, tradeThroughAtFormation, originRefId)
        map.put(state.equalLevelRefMap, originRefId, resultId)

    resultId

// -----------------------------------------------------------------------------
// submitSessionFact
// Submits a confirmed session-derived extreme fact from the Session Engine
// (e.g., PDH, PDL, weekly high/low, session high/low). Uses the identical
// lifecycle and resolution machinery as swing-based and equal-level
// liquidity (frozen spec section 15) — no separate resolution vocabulary.
//
// Returns: the new liquidity object's id.
// -----------------------------------------------------------------------------
export submitSessionFact(LiquidityEngineState state, string orientation, float level, float toleranceOffset, float proximityBand, int stalenessBars, int reactionWindowBars, int formationBar, bool tradeThroughAtFormation, int originRefId) =>
    f_createObject(state, ORIGIN_SESSION, orientation, level, toleranceOffset, proximityBand, stalenessBars, reactionWindowBars, formationBar, tradeThroughAtFormation, originRefId)

// -----------------------------------------------------------------------------
// advance
// Processes interaction detection for the current bar against every
// liquidity object in `state` not yet in the RESOLVED state. Must be
// called exactly once per bar, after any new facts for that bar have been
// submitted, and only with the current (closing/confirmed) bar's
// high/low/close.
//
// PATCH (perf/maintainability): iterates the dedicated live-id set
// (state.liveIds) instead of scanning the full historical registry, so
// cost per bar is proportional to the number of currently-unresolved
// objects, not to the total historical object count.
//
// FIX (empty-array loop direction): iterates with an explicit `by -1`.
// Without an explicit step, Pine infers loop direction once by comparing
// the from/to endpoints; when state.liveIds is empty this infers the
// WRONG (ascending) direction and executes two out-of-bounds iterations
// instead of zero. An explicit negative step makes the continuation test
// depend on the step's own sign, so the empty case correctly runs zero
// times.
//
// Each object is still evaluated independently, so simultaneous
// multi-level triggers (a single bar exceeding several stacked liquidity
// levels) continue to be handled correctly with no special-case logic.
// -----------------------------------------------------------------------------
export advance(LiquidityEngineState state, int barIndex, float high, float low, float close) =>
    // Snapshot the live-id count before the loop. Objects may be removed
    // from state.liveIds mid-iteration as they resolve; iterating downward
    // avoids skipping an element after a removal shifts subsequent indices.
    for i = array.size(state.liveIds) - 1 to 0 by -1
        objId = array.get(state.liveIds, i)
        obj = f_getObjectRef(state, objId)
        if not na(obj)
            if obj.lifecycleState == STATE_RESOLVING
                f_processResolving(state, obj, barIndex, close)
            else if obj.lifecycleState == STATE_ACTIVE or obj.lifecycleState == STATE_APPROACHED
                f_processActiveOrApproached(state, obj, barIndex, high, low, close)
    true

// -----------------------------------------------------------------------------
// getActiveObjects
// Returns CLONES of all liquidity objects in `state` NOT in the RESOLVED
// state (i.e., Active, Approached, or Resolving). Read-only query;
// returned instances are copies and do not share state with the internal
// registry.
//
// FIX (empty-array loop direction): explicit `by 1` — see advance() note.
// -----------------------------------------------------------------------------
export getActiveObjects(LiquidityEngineState state) =>
    array<LiquidityObject> result = array.new<LiquidityObject>()
    for i = 0 to array.size(state.liveIds) - 1 by 1
        objId = array.get(state.liveIds, i)
        obj = f_getObjectRef(state, objId)
        if not na(obj)
            array.push(result, f_cloneObject(obj))
    result

// -----------------------------------------------------------------------------
// getResolvedObjects
// Returns CLONES of all liquidity objects in `state` currently in the
// RESOLVED state, retained for historical/analytical query per the
// Resolution Rules.
//
// FIX (empty-array loop direction): explicit `by 1` — see advance() note.
// -----------------------------------------------------------------------------
export getResolvedObjects(LiquidityEngineState state) =>
    array<LiquidityObject> result = array.new<LiquidityObject>()
    for i = 0 to array.size(state.registry) - 1 by 1
        obj = array.get(state.registry, i)
        if obj.lifecycleState == STATE_RESOLVED
            array.push(result, f_cloneObject(obj))
    result

// -----------------------------------------------------------------------------
// getObjectById
// Lookup helper. Returns a CLONE of the liquidity object with the given id
// within `state`, or `na` if no such object exists.
// -----------------------------------------------------------------------------
export getObjectById(LiquidityEngineState state, int objectId) =>
    obj = f_getObjectRef(state, objectId)
    na(obj) ? na : f_cloneObject(obj)

// -----------------------------------------------------------------------------
// objectExists
// Validation helper. Returns true if the given id refers to a currently
// registered liquidity object within `state`.
// -----------------------------------------------------------------------------
export objectExists(LiquidityEngineState state, int objectId) =>
    map.contains(state.idIndexMap, objectId)

// -----------------------------------------------------------------------------
// getEventLog
// Returns CLONES of the complete, immutable, append-only liquidity event
// log for `state`, in emission order.
//
// FIX (empty-array loop direction): explicit `by 1` — see advance() note.
// -----------------------------------------------------------------------------
export getEventLog(LiquidityEngineState state) =>
    array<LiquidityEvent> result = array.new<LiquidityEvent>()
    for i = 0 to array.size(state.eventLog) - 1 by 1
        array.push(result, f_cloneEvent(array.get(state.eventLog, i)))
    result

// -----------------------------------------------------------------------------
// getEventsForObject
// Lookup helper. Returns CLONES of all events pertaining to a specific
// liquidity object id within `state`, in emission order.
//
// FIX (empty-array loop direction): explicit `by 1` — see advance() note.
// -----------------------------------------------------------------------------
export getEventsForObject(LiquidityEngineState state, int objectId) =>
    array<LiquidityEvent> result = array.new<LiquidityEvent>()
    for i = 0 to array.size(state.eventLog) - 1 by 1
        evt = array.get(state.eventLog, i)
        if evt.objectId == objectId
            array.push(result, f_cloneEvent(evt))
    result
