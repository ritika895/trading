// LIFECYCLE MANAGER — Manages pool state transitions (FORMED → ACTIVE only)
// =====================================================================================================================

lifecycle_transitionFormedToActive(LiquidityPool pool) =>
    // FORMED → ACTIVE transition logic
    // Read-only operation on pool object, returns new state
    barsSinceFormed = bar_index - pool.formedBar
    if barsSinceFormed >= i_formedToActiveBars
        PoolState.active
    else
        pool.state

lifecycle_updatePoolState(int poolIndex) =>
    // Update state of a single pool in the registry
    registrySize = array.size(g_registry)
    if poolIndex >= 0 and poolIndex < registrySize
        pool = array.get(g_registry, poolIndex)
        
        // Determine new state
        if pool.state == PoolState.formed
            newState = lifecycle_transitionFormedToActive(pool)
            pool.state := newState
            array.set(g_registry, poolIndex, pool)

lifecycle_processAllPools() =>
    // Process all pools in the registry for state transitions
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            if i >= 0 and i < registrySize
                lifecycle_updatePoolState(i)

// =====================================================================================================================
// LIFECYCLE VERIFICATION — Read-only integrity checks
// =====================================================================================================================

lifecycle_countPoolsByState(PoolState stateToCount) =>
    count = 0
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            if i >= 0 and i < registrySize
                pool = array.get(g_registry, i)
                if pool.state == stateToCount
                    count := count + 1
    count

lifecycle_checkIntegrity() =>
    // Lifecycle Integrity: Sum of all implemented valid states == Total Pools
    // Extend this sum as new lifecycle states (CONFIRMED, ARCHIVED, etc.) are implemented
    totalPools = array.size(g_registry)
    formedCount = lifecycle_countPoolsByState(PoolState.formed)
    activeCount = lifecycle_countPoolsByState(PoolState.active)
    reinforcedCount = lifecycle_countPoolsByState(PoolState.reinforced)
    sweptCount = lifecycle_countPoolsByState(PoolState.swept)
    // confirmedCount = lifecycle_countPoolsByState(PoolState.confirmed) // Future: uncomment when implemented
    // archivedCount = lifecycle_countPoolsByState(PoolState.archived)   // Future: uncomment when implemented
    (formedCount + activeCount + reinforcedCount + sweptCount) == totalPools

// =====================================================================================================================
// REPLACEMENT ENGINE VERIFICATION — Read-only integrity checks
// =====================================================================================================================

replacement_checkIntegrity() =>
    // Replacement Integrity: All candidates processed and accounted for
    // Integrity passes when: Candidates Accepted + Candidates Rejected == Candidates Processed
    // This correctly reflects all replacement decisions made by the engine.
    totalProcessed = g_candidatesProcessed
    totalAccounted = g_candidatesAccepted + g_candidatesRejected
    totalAccounted == totalProcessed

