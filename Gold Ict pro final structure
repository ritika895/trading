// -----------------------------------------------------------------------------
// SECTION: Shared Tier 1 Utility — swing-agnostic, pure, stateless
// (frozen spec §6)
// -----------------------------------------------------------------------------
// Computes whether closePrice has closed beyond level, in the invalidating
// direction implied by swingType. This is the shared primitive both
// Structure Classification (retirement) and, in the future, other
// consumers (Liquidity, CHoCH) should use — a single source of truth for
// "did price close through this level," decoupled from any one module's
// interpretation of what that fact means.
//
// Does NOT modify or replace BOS's existing frozen
// bos_evaluateBreak_CandleClose() — that function is left untouched by
// design (frozen spec §6). This is a new, independent utility; BOS is not
// wired to it in this deliverable.
//
// Tie-break: exact equality (closePrice == level) is NOT a cross — strict
// inequality required, consistent with the same rule already frozen in
// BOS (Edge Case E1).
deriveLevelCrossed(float closePrice, float level, int swingType) =>
    bool crossed = false
    if swingType == SWING_HIGH
        crossed := closePrice > level
    else if swingType == SWING_LOW
        crossed := closePrice < level
    crossed

// -----------------------------------------------------------------------------
// SECTION: Types / Constants
// -----------------------------------------------------------------------------

const int STRUCTCLS_STATE_ACTIVE  = 1
const int STRUCTCLS_STATE_RETIRED = 2

// -----------------------------------------------------------------------------
// SECTION: Persistent State (frozen spec §2, §5)
// -----------------------------------------------------------------------------
// Parallel arrays, not UDTs — consistent with this project's established
// style (Swing Database, BOS's own bos_database structure). Every entry
// ever activated remains permanently in these arrays (retired entries are
// never removed), per the immutability principle already established
// project-wide for confirmed historical records.

var array<int> structcls_swingIds     = array.new_int()   // swing_id (Swing Database reference)
var array<int> structcls_states       = array.new_int()   // STRUCTCLS_STATE_ACTIVE / STRUCTCLS_STATE_RETIRED
var array<int> structcls_activatedBar = array.new_int()   // true confirmation-bar index (see module header)
var array<int> structcls_retiredBar   = array.new_int()   // NO_INDEX until retired, then permanent

// swing_id -> array index. Mirrors the identical pattern already
// established and frozen in BOS (bos_swing_index) — O(1) lookup, presence
// of a key also structurally guarantees no duplicate swing_id can ever be
// pushed (see structcls_processBar), so no separate O(n^2) duplicate scan
// is needed in validation, unlike the Swing Database's own check.
var map<int, int> structcls_swingIndex = map.new<int, int>()

// -----------------------------------------------------------------------------
// SECTION: Public Interface — Write Path (frozen spec §3, §4, §9, §10, §11, §12)
// -----------------------------------------------------------------------------

// Orchestrates the per-bar Structure Classification pipeline. Self-
// contained: confirmed-bar gating happens inside this function, matching
// the same self-protecting-API pattern already established in
// bos_processBar() — correct regardless of caller discipline.
//
// ACTIVATION (frozen spec §3, §12): consumes the Replacement Engine's own
// currentConfirmedSwingIds for this bar. Every swing_id present there that
// is not already tracked becomes Active, unconditionally.
//
// RETIREMENT (frozen spec §4, §10): runs AFTER activation, over the FULL
// tracked set (including anything just activated this bar). Uses
// deriveLevelCrossed() against this bar's close. A swing already
// invalidated by the very bar it confirmed on retires immediately rather
// than lingering falsely Active for one extra bar.
structcls_processBar(int bar_idx, float close_price) =>
    if barstate.isconfirmed
        // --- Activation ---
        int confirmedCount = array.size(currentConfirmedSwingIds)

        if confirmedCount > 0
            for i = 0 to confirmedCount - 1
                int newSwingId = array.get(currentConfirmedSwingIds, i)

                if not map.contains(structcls_swingIndex, newSwingId)
                    array.push(structcls_swingIds, newSwingId)
                    array.push(structcls_states, STRUCTCLS_STATE_ACTIVE)
                    array.push(structcls_activatedBar, bar_idx)
                    array.push(structcls_retiredBar, NO_INDEX)
                    map.put(structcls_swingIndex, newSwingId, array.size(structcls_swingIds) - 1)

        // --- Retirement ---
        // O(n) in total tracked swing count (frozen spec §11) — retired
        // entries are never removed, so this scans every entry ever
        // activated, not just currently-active ones.
        int totalCount = array.size(structcls_swingIds)

        if totalCount > 0
            for i = 0 to totalCount - 1
                if array.get(structcls_states, i) == STRUCTCLS_STATE_ACTIVE
                    int activeSwingId = array.get(structcls_swingIds, i)
                    [swingType, swingLevel, _, _, exists] = getSwing(activeSwingId)

                    if exists and deriveLevelCrossed(close_price, swingLevel, swingType)
                        array.set(structcls_states, i, STRUCTCLS_STATE_RETIRED)
                        array.set(structcls_retiredBar, i, bar_idx)

// -----------------------------------------------------------------------------
// SECTION: Public Interface — Read Path
// -----------------------------------------------------------------------------
// All accessors are read-only BY CONVENTION, matching the same
// Pine-has-no-compiler-enforced-immutability caveat already documented for
// BOS's own read accessors. Every value returned here is a primitive
// (int/float/bool/string) — no live references, no UDTs, matching the
// copy-not-reference discipline already established project-wide.

// Returns the bounded set of currently active structural swing IDs, in
// ascending swing_id / insertion order (frozen spec §14) — deterministic,
// satisfying the cross-module ordering obligation owed to BOS.
structcls_getActiveStructuralSwingIds() =>
    array<int> result = array.new_int()
    int total = array.size(structcls_swingIds)

    if total > 0
        for i = 0 to total - 1
            if array.get(structcls_states, i) == STRUCTCLS_STATE_ACTIVE
                array.push(result, array.get(structcls_swingIds, i))

    result

// Returns the swing's price level, sourced directly from the Swing
// Database via the existing getSwing() accessor — no duplicated storage.
structcls_getLevel(int swingId) =>
    [_, price, _, _, exists] = getSwing(swingId)
    exists ? price : na

// Returns the true confirmation-bar index — the bar on which THIS MODULE
// observed the swing's confirmation (frozen spec §13) — NOT the Swing
// Database's swingBar (the pivot's own, earlier bar).
structcls_getConfirmedBar(int swingId) =>
    int result = NO_INDEX

    if map.contains(structcls_swingIndex, swingId)
        int idx = map.get(structcls_swingIndex, swingId)
        result := array.get(structcls_activatedBar, idx)

    result

// Returns "bullish" / "bearish", derived at read time from the Swing
// Database's swingType (frozen spec §8) — never persisted. Exists solely
// to satisfy BOS's existing frozen string-based direction contract; not
// a new independent concept.
structcls_getDirection(int swingId) =>
    [swingType, _, _, _, exists] = getSwing(swingId)
    string result = ""

    if exists
        result := swingType == SWING_HIGH ? "bullish" : "bearish"

    result

// Pass-through of the Swing Database's own lifecycle status for this
// swing_id — always STATUS_CONFIRMED for anything reachable through this
// module in practice, per this module's own activation guarantee. Returns
// the Swing Database's actual int constant, NOT a string — see module
// header "KNOWN FOLLOW-UP" regarding a future BOS adapter.
structcls_getLifecycleState(int swingId) =>
    [_, _, _, status, exists] = getSwing(swingId)
    exists ? status : STATUS_REJECTED

// Convenience membership check — true if swingId is currently Active.
structcls_isStructurallyActive(int swingId) =>
    bool result = false

    if map.contains(structcls_swingIndex, swingId)
        int idx = map.get(structcls_swingIndex, swingId)
        result := array.get(structcls_states, idx) == STRUCTCLS_STATE_ACTIVE

    result

// Returns the bar_idx this swing was retired on, or NO_INDEX if it has
// not been retired (or is not tracked at all). Exposed for debug/
// visualization use, matching the same purpose already established for
// the original interface reference document's equivalent accessor.
structcls_getRetirementBar(int swingId) =>
    int result = NO_INDEX

    if map.contains(structcls_swingIndex, swingId)
        int idx = map.get(structcls_swingIndex, swingId)
        result := array.get(structcls_retiredBar, idx)

    result

// -----------------------------------------------------------------------------
// SECTION: Internal Validation
// -----------------------------------------------------------------------------
// Lightweight integrity check, matching the discipline already established
// throughout this project. Not wired to any specific debug-mode input in
// this module (Structure Classification has none of its own) — available
// for the host script's own validation plumbing to call as needed.

structcls_isValidState(int stateValue) =>
    stateValue == STRUCTCLS_STATE_ACTIVE or stateValue == STRUCTCLS_STATE_RETIRED

// No duplicate-ID scan is included here, unlike the Swing Database's own
// O(n^2) check — duplicates are structurally impossible by construction,
// since structcls_processBar() only ever pushes a new entry after an
// explicit map.contains() guard (mirroring the identical, already-frozen
// pattern in bos_recordBreak()). This is a deliberate, justified omission,
// not an oversight.
structcls_databaseIsValid() =>
    bool valid = true
    int size = array.size(structcls_swingIds)
    int statesSize = array.size(structcls_states)
    int activatedSize = array.size(structcls_activatedBar)
    int retiredSize = array.size(structcls_retiredBar)

    if statesSize != size or activatedSize != size or retiredSize != size
        valid := false

    if size > 0
        for i = 0 to size - 1
            if not structcls_isValidState(array.get(structcls_states, i))
                valid := false

    valid

//====================================================================
// PER-BAR EXECUTION
//====================================================================

resetCurrentBarEvents()

if hasCandidateHigh
    [updatedTypeHigh, updatedIdHigh, updatedHighSwingIdHigh, updatedLowSwingIdHigh, updatedTransitionIdHigh, createdHighSwing] = processCandidate(SWING_HIGH, candidateHighPrice, candidateHighBar, nextSwingId)

    activePendingSwingType := updatedTypeHigh
    activePendingSwingId := updatedIdHigh
    activePendingHighSwingId := updatedHighSwingIdHigh
    activePendingLowSwingId := updatedLowSwingIdHigh
    activeTransitionSwingId := updatedTransitionIdHigh

    if createdHighSwing
        nextSwingId += 1

if hasCandidateLow
    [updatedTypeLow, updatedIdLow, updatedHighSwingIdLow, updatedLowSwingIdLow, updatedTransitionIdLow, createdLowSwing] = processCandidate(SWING_LOW, candidateLowPrice, candidateLowBar, nextSwingId)

    activePendingSwingType := updatedTypeLow
    activePendingSwingId := updatedIdLow
    activePendingHighSwingId := updatedHighSwingIdLow
    activePendingLowSwingId := updatedLowSwingIdLow
    activeTransitionSwingId := updatedTransitionIdLow

    if createdLowSwing
        nextSwingId += 1

// Structure Classification per-bar call (frozen spec §12 / Host Script
// Call Site). Runs AFTER the Swing Database / Replacement Engine's own
// per-bar processing above, which populates currentConfirmedSwingIds for
// this bar. A subsequent bos_processBar(bar_index, close, na) call is NOT
// present because no BOS Engine section exists in this host script yet;
// when one is added, it must be called immediately after this line, per
// the frozen required ordering (Swing Database -> Structure
// Classification -> BOS).
structcls_processBar(bar_index, close)

//====================================================================
// VISUALIZATION
//====================================================================

isDeveloperMode() =>
    displayMode == DISPLAY_DEVELOPER

isTestMode() =>
    displayMode == DISPLAY_TEST

drawDeveloperDebugLabel(int eventType, int swingType, int swingId, float swingPrice, int swingBar) =>
    if showDebugLabels and isDeveloperMode()
        string sideText = swingType == SWING_HIGH ? "High" : "Low"
        string eventText = eventType == EVENT_ACCEPTED ? "Accepted" : eventType == EVENT_REPLACED ? "Replaced" : "Rejected"
        string labelText = eventText + " " + sideText + " #" + str.tostring(swingId)
        color labelColor = eventType == EVENT_ACCEPTED ? acceptedColor : eventType == EVENT_REPLACED ? replacedColor : rejectedColor

        label.new(swingBar, swingPrice, labelText, xloc = xloc.bar_index, yloc = yloc.price, style = swingType == SWING_HIGH ? label.style_label_down : label.style_label_up, color = labelColor, textcolor = color.white, size = size.tiny)

drawConfirmedSwingLabel(int swingType, int swingId, float swingPrice, int swingBar) =>
    if showConfirmedSwings and (isDeveloperMode() or isTestMode())
        string swingText = swingType == SWING_HIGH ? "H" : "L"
        string labelText = isDeveloperMode() ? swingText + " #" + str.tostring(swingId) : swingText

        label.new(swingBar, swingPrice, labelText, xloc = xloc.bar_index, yloc = yloc.price, style = swingType == SWING_HIGH ? label.style_label_down : label.style_label_up, color = color.new(color.blue, 0), textcolor = color.white, size = size.small)

int confirmedCount = array.size(currentConfirmedSwingIds)

if confirmedCount > 0
    for index = 0 to confirmedCount - 1
        int confirmedType = array.get(currentConfirmedSwingTypes, index)
        int confirmedId = array.get(currentConfirmedSwingIds, index)
        float confirmedPrice = array.get(currentConfirmedSwingPrices, index)
        int confirmedBar = array.get(currentConfirmedSwingBars, index)

        drawConfirmedSwingLabel(confirmedType, confirmedId, confirmedPrice, confirmedBar)

int eventCount = array.size(currentEventTypes)

if eventCount > 0
    for index = 0 to eventCount - 1
        int eventType = array.get(currentEventTypes, index)
        int eventSwingType = array.get(currentEventSwingTypes, index)
        int eventSwingId = array.get(currentEventSwingIds, index)
        float eventPrice = array.get(currentEventPrices, index)
        int eventBar = array.get(currentEventBars, index)

        drawDeveloperDebugLabel(eventType, eventSwingType, eventSwingId, eventPrice, eventBar)

plotshape(hasCandidateHigh and isDeveloperMode(), title = "Candidate High", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 75), size = size.tiny, offset = -pivotRightBars)

plotshape(hasCandidateLow and isDeveloperMode(), title = "Candidate Low", style = shape.triangleup, location = location.belowbar, color = color.new(color.green, 75), size = size.tiny, offset = -pivotRightBars)
