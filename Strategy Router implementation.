f_route_strategies(StrategyContextSet contextSet, StrategyMetadata[] reg) =>
    DispatchResult[] results = array.new<DispatchResult>()
    int dispatchedCount = 0
    int shadowCount = 0
    int rejectedCount = 0
    
    if array.size(contextSet.contexts) > 0
        for i = 0 to array.size(contextSet.contexts) - 1
