// LIQUIDITY SWEEP ENGINE — PURE MODULE: detects when price sweeps an existing liquidity pool
// NO global variable modifications. Returns array of SweepEvent for top-level to apply.
// A sweep occurs when price wicks beyond the pool but closes back on the other side.
// =====================================================================================================================

sweep_detect(int poolIndex) =>
    // Detects if a specific pool was swept on the current bar
    // Returns a SweepEvent if a sweep is detected, na otherwise
    // PURE FUNCTION: read-only, no global modifications
    SweepEvent event = na
    registrySize = array.size(g_registry)
    if poolIndex >= 0 and poolIndex < registrySize
        pool = array.get(g_registry, poolIndex)
        
        // Only ACTIVE or REINFORCED pools can be swept. FORMED pools cannot be swept.
        if pool.state == PoolState.active or pool.state == PoolState.reinforced
            float currentHigh = high
            float currentLow = low
            float currentClose = close
            
            if pool.isResistanceSide
                // Resistance Pool (High) Sweep Logic:
                // Candle High trades above the pool price by a configurable tolerance
                // Candle Close finishes back below the pool
                if currentHigh > pool.priceLevel + i_sweepTolerance and currentClose < pool.priceLevel
                    event := SweepEvent.new(poolIndex, false, currentHigh)
            else
                // Support Pool (Low) Sweep Logic:
                // Candle Low trades below the pool price by a configurable tolerance
                // Candle Close finishes back above the pool
                if currentLow < pool.priceLevel - i_sweepTolerance and currentClose > pool.priceLevel
                    event := SweepEvent.new(poolIndex, true, currentLow)
    
    event

sweep_validate(SweepEvent event) =>
    // Validates a detected sweep event (e.g., ensures it meets additional criteria)
    // Currently acts as a pass-through validation, can be extended with extra filters
    // PURE FUNCTION: read-only, no global modifications
    if na(event)
        false
    else
        // Ensure the pool index is valid and the pool still exists in registry
        if event.poolIndex >= 0 and event.poolIndex < array.size(g_registry)
            pool = array.get(g_registry, event.poolIndex)
            // Double-check that the pool is in a sweepable state
            if pool.state == PoolState.active or pool.state == PoolState.reinforced
                true
            else
                false
        else
            false

sweep_markPool(SweepEvent event) =>
    // Calculates the updated pool fields for a sweep event
    // Returns a new LiquidityPool object with sweep fields updated and state set to SWEPT
    // PURE FUNCTION: read-only on globals, returns modified pool object
    LiquidityPool updatedPool = na
    if not na(event)
        if event.poolIndex >= 0 and event.poolIndex < array.size(g_registry)
            pool = array.get(g_registry, event.poolIndex)
            pool.hasBeenSwept := true
            pool.sweepBar := bar_index
            pool.sweepPrice := event.sweepWickPrice
            pool.sweepCount := pool.sweepCount + 1
            pool.state := PoolState.swept
            updatedPool := pool
    updatedPool

sweep_processPools() =>
    // Processes all pools in the registry to detect sweeps
    // Returns array of validated SweepEvent objects
    // PURE FUNCTION: read-only, no global modifications
    events = array.new<SweepEvent>()
    if i_enableSweep
        registrySize = array.size(g_registry)
        if registrySize > 0
            for i = 0 to registrySize - 1
                if i >= 0 and i < registrySize
                    event = sweep_detect(i)
                    if not na(event)
                        if sweep_validate(event)
                            array.push(events, event)
    events

