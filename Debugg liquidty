// =====================================================================================================================
// CORE DATA MODEL
// =====================================================================================================================

enum PoolType
    eq_highs        = "Equal Highs"
    eq_lows         = "Equal Lows"
    swing_high      = "Single-Swing High"
    swing_low       = "Single-Swing Low"
    trendline_high  = "Trendline High"
    trendline_low   = "Trendline Low"
    session_high    = "Session High"
    session_low     = "Session Low"

enum PoolState
    created         = "Created"
    formed          = "Formed"
    active          = "Active"
    reinforced      = "Reinforced"
    confirmed       = "Confirmed"
    archived        = "Archived"

enum ReplacementDecision
    kept            = "Kept"
    replaced        = "Replaced"
    ignored         = "Ignored"

// Minimal candidate type — created by Detection Layer only
type DetectionCandidate
    PoolType  poolType
    bool      isResistanceSide
    float     priceLevel
    int       detectedBar

// LiquidityPool — owned by Registry, state managed by Lifecycle Manager
type LiquidityPool
    int         poolID
    PoolType    poolType
    bool        isResistanceSide
    float       priceLevel
    int         originBar
    PoolState   state              // Managed by Lifecycle Manager
    int         reinforcementCount  // Placeholder for future use
    float       confidence          // Placeholder for future use
    int         formedBar           // When pool entered FORMED state

// Detection context
type DetectionContext
    float  pivotHighPrice
    int    pivotHighBar
    bool   hasPivotHigh
    float  pivotLowPrice
    int    pivotLowBar
    bool   hasPivotLow

// Visualization item (label or line) tracker
type VizItem
    int    itemType      // 0 = label, 1 = line
    label  lbl           // non-na only if itemType == 0
    line   ln            // non-na only if itemType == 1

// Replacement decision record
type ReplacementRecord
    int                 candidateIndex
    ReplacementDecision decision
    int                 conflictingPoolID

// Replacement decision result
type ReplacementResult
    bool                accept       // true = accept candidate, false = reject
    ReplacementDecision decision     // decision type: kept, replaced, ignored
    int                 conflictPoolID // ID of conflicting pool if any

