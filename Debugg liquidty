registry_getHighestPoolID() =>
    if array.size(g_registry) == 0
        0
    else
        if array.size(g_registry) > 0
            lastPool = array.get(g_registry, array.size(g_registry) - 1)
            lastPool.poolID
        else
            0

registry_checkIntegrity() =>
    // Registry Integrity: Size == Highest Pool ID (IDs are sequential, nothing deleted)
    registrySize = array.size(g_registry)
    highestID = registry_getHighestPoolID()
    registrySize == highestID

registry_checkDuplicateIDs() =>
    // Currently no duplicates exist — IDs are strictly sequential
    false

// =====================================================================================================================
// REPLACEMENT ENGINE — Pure functions (read-only), NO global variable modifications
// =====================================================================================================================

// ===== VERIFICATION RULE (TEMPORARY) =====
// This replacement rule is intentionally simple for verification purposes only.
//
// VERIFICATION RULE:
// When a newly detected pool conflicts with an existing pool (same type, price within tolerance):
//   → KEEP the OLDER pool
//   → REJECT the NEW pool
//
// Future versions will implement confidence-based replacement scoring.
// Confidence-based replacement is intentionally disabled in this build.
// MERGE logic is intentionally disabled in this build.
// ==========================================

replacement_findConflict(DetectionCandidate newCandidate) =>
    // Find existing pool with same type and overlapping price level
    // Returns pool index if conflict found, -1 if no conflict
    // PURE FUNCTION: read-only, no global modifications
    conflictIndex = -1
    registrySize = array.size(g_registry)
    
    if registrySize > 0
        for i = 0 to registrySize - 1
            if i >= 0 and i < registrySize
                existingPool = array.get(g_registry, i)
                
                // Check if same pool type
                if existingPool.poolType == newCandidate.poolType
                    // Check if price levels are within tolerance
                    priceDiff = math.abs(existingPool.priceLevel - newCandidate.priceLevel)
                    if priceDiff <= i_replacementTolerance
                        conflictIndex := i
                        break
    
    conflictIndex

replacement_decideAction(DetectionCandidate newCandidate, int conflictPoolIndex) =>
    // ===== VERIFICATION RULE (TEMPORARY) =====
    // When conflict detected: KEEP existing pool, REJECT new pool
    // This is a deterministic temporary rule for verification purposes only.
    // PURE FUNCTION: read-only, no global modifications
    //
    // Future confidence-based replacement is NOT implemented in this verification build.
    // When confidence module is available, this function will:
    //   - Compare confidence scores of new vs existing pool
    //   - REPLACE if new pool confidence > existing pool confidence
    //   - KEEP existing if existing confidence >= new pool confidence
    // ==========================================
    ReplacementDecision.kept

replacement_processCandidates() =>
    // Process all candidates through replacement engine
    // Returns array of ReplacementResult objects with all decision data
    // PURE FUNCTION: read-only, no global modifications
    results = array.new<ReplacementResult>()
    candidatesSize = array.size(g_swingCandidatesThisBar)
    
    if candidatesSize > 0
        for i = 0 to candidatesSize - 1
            if i >= 0 and i < candidatesSize
                candidate = array.get(g_swingCandidatesThisBar, i)
                
                if not i_enableReplacement
                    // Replacement engine disabled: accept all candidates
                    result = ReplacementResult.new(true, ReplacementDecision.ignored, -1)
                    array.push(results, result)
                else
                    // Check for conflicts
                    conflictIndex = replacement_findConflict(candidate)
                    
                    if conflictIndex == -1
                        // No conflict: accept candidate
                        result = ReplacementResult.new(true, ReplacementDecision.ignored, -1)
                        array.push(results, result)
                    else
                        // Conflict found: decide action
                        if conflictIndex >= 0 and conflictIndex < array.size(g_registry)
                            existingPool = array.get(g_registry, conflictIndex)
                            action = replacement_decideAction(candidate, conflictIndex)
                            
                            if action == ReplacementDecision.kept
                                // Keep existing: reject new candidate
                                result = ReplacementResult.new(false, ReplacementDecision.kept, existingPool.poolID)
                                array.push(results, result)
                            else if action == ReplacementDecision.replaced
                                // ===== REPLACE ACTION NOT IMPLEMENTED IN VERIFICATION BUILD =====
                                // In future versions, this will:
                                //   - Remove existingPool from registry
                                //   - Accept new candidate
                                // For now, fall through to default rejection.
                                // ================================================================
                                result = ReplacementResult.new(false, ReplacementDecision.replaced, existingPool.poolID)
                                array.push(results, result)
                            else
                                // Unknown decision: reject candidate as safety default
                                result = ReplacementResult.new(false, ReplacementDecision.ignored, -1)
                                array.push(results, result)
                        else
                            // Invalid conflict index: reject candidate as safety default
                            result = ReplacementResult.new(false, ReplacementDecision.ignored, -1)
                            array.push(results, result)
    
    results

// =====================================================================================================================
// LIFECYCLE MANAGER — Manages pool state transitions (FORMED → ACTIVE only)
// =====================================================================================================================

lifecycle_transitionFormedToActive(LiquidityPool pool) =>
    // FORMED → ACTIVE transition logic
    // Read-only operation on pool object, returns new state
    barsSinceFormed = bar_index - pool.formedBar
    if barsSinceFormed >= i_formedToActiveBars
        PoolState.active
    else
        pool.state

lifecycle_updatePoolState(int poolIndex) =>
    // Update state of a single pool in the registry
    registrySize = array.size(g_registry)
    if poolIndex >= 0 and poolIndex < registrySize
        pool = array.get(g_registry, poolIndex)
        
        // Determine new state
        if pool.state == PoolState.formed
            newState = lifecycle_transitionFormedToActive(pool)
            pool.state := newState
            array.set(g_registry, poolIndex, pool)

lifecycle_processAllPools() =>
    // Process all pools in the registry for state transitions
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            if i >= 0 and i < registrySize
                lifecycle_updatePoolState(i)

// =====================================================================================================================
// LIFECYCLE VERIFICATION — Read-only integrity checks
// =====================================================================================================================

lifecycle_countPoolsByState(PoolState stateToCount) =>
    count = 0
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            if i >= 0 and i < registrySize
                pool = array.get(g_registry, i)
                if pool.state == stateToCount
                    count := count + 1
    count

lifecycle_checkIntegrity() =>
    // Lifecycle Integrity: FORMED + ACTIVE == Registry Size
    totalPools = array.size(g_registry)
    formedCount = lifecycle_countPoolsByState(PoolState.formed)
    activeCount = lifecycle_countPoolsByState(PoolState.active)
    (formedCount + activeCount) == totalPools

// =====================================================================================================================
// REPLACEMENT ENGINE VERIFICATION — Read-only integrity checks
// =====================================================================================================================

replacement_checkIntegrity() =>
    // Replacement Integrity: All candidates processed and accounted for
    // Integrity passes when: Candidates Accepted + Candidates Rejected == Candidates Processed
    // This correctly reflects all replacement decisions made by the engine.
    totalProcessed = g_candidatesProcessed
    totalAccounted = g_candidatesAccepted + g_candidatesRejected
    totalAccounted == totalProcessed

