    PoolType    poolType
    bool        isResistanceSide
    float       priceLevel
    int         originBar
    PoolState   state              // Managed by Lifecycle Manager
    int         reinforcementCount  // Managed by Reinforcement Engine
    float       confidence          // Managed by Confidence Engine
    int         formedBar           // When pool entered FORMED state
    bool        hasBeenSwept       // Managed by Liquidity Sweep Engine
    int         sweepBar           // Managed by Liquidity Sweep Engine
    float       sweepPrice         // Managed by Liquidity Sweep Engine
    int         sweepCount         // Managed by Liquidity Sweep Engine

// Detection context
