// =========================================================================
// MODULE 5: UTILITY FUNCTIONS
// =========================================================================
f_get_session_type() =>
    SessionType s = SessionType.NONE
    if not na(time(timeframe.period, inp_asian_session))
        s := SessionType.ASIAN
    else if not na(time(timeframe.period, inp_london_session))
        s := SessionType.LONDON
    else if not na(time(timeframe.period, inp_ny_session))
        s := SessionType.NEW_YORK
    s

f_is_equal(float a, float b) =>
    math.abs(a - b) < EPSILON

f_is_crossed(float level, float barHigh, float barLow) =>
    barHigh >= level and barLow <= level

f_format_price(float p) =>
    str.tostring(p, format.mintick)

f_generate_id() =>
    int(timestamp(year, month, dayofmonth, hour, minute, second)) + bar_index

f_state_to_string(LifecycleState s) =>
    string str = "UNKNOWN"
    if s == LifecycleState.FORMED
        str := "FORMED"
    else if s == LifecycleState.ACTIVE
        str := "ACTIVE"
    else if s == LifecycleState.REINFORCED
        str := "REINFORCED"
    else if s == LifecycleState.SWEPT
        str := "SWEPT"
    else if s == LifecycleState.INVALIDATED
        str := "INVALIDATED"
    else if s == LifecycleState.EXPIRED
        str := "EXPIRED"
    str

f_priority_to_string(PriorityClass p) =>
    string str = "NONE"
    if p == PriorityClass.CRITICAL
        str := "CRITICAL"
    else if p == PriorityClass.HIGH
        str := "HIGH"
    else if p == PriorityClass.MEDIUM
        str := "MEDIUM"
    else if p == PriorityClass.LOW
        str := "LOW"
    else if p == PriorityClass.BACKGROUND
        str := "BACKGROUND"
    str

// =========================================================================
// PHASE 1: DETECTION LAYER
// =========================================================================
var float[] detection_highs = array.new_float(0)
var float[] detection_lows  = array.new_float(0)

f_detect_swings() =>
    float swingHigh = ta.pivothigh(high, inp_lookback, inp_lookback)
    float swingLow  = ta.pivotlow(low, inp_lookback, inp_lookback)
    
    if bar_index >= inp_lookback
        if not na(swingHigh)
            array.push(detection_highs, swingHigh)
        if not na(swingLow)
            array.push(detection_lows, swingLow)
            
        if array.size(detection_highs) > MAX_POOL_LIMIT
            array.shift(detection_highs)
        if array.size(detection_lows) > MAX_POOL_LIMIT
            array.shift(detection_lows)

f_generate_candidates() =>
    LiquidityPool[] candidates = array.new<LiquidityPool>(0)
    SessionType currentSession = f_get_session_type()
    
    if array.size(detection_highs) > 0
        float topHigh = array.get(detection_highs, array.size(detection_highs) - 1)
        LiquidityPool bearPool = LiquidityPool.new(
             id              = f_generate_id(),
             pType           = PoolType.BEARISH,
             state           = LifecycleState.FORMED,
             price           = topHigh,
             barCreated      = bar_index - inp_lookback,
             lastTouchBar    = bar_index - inp_lookback,
             touchCount      = 0,
             confidence      = 50.0,
             sessionCreated  = currentSession,
             isSwept         = false,
             visual          = na
         )
        array.push(candidates, bearPool)
        array.pop(detection_highs)
        
    if array.size(detection_lows) > 0
        float topLow = array.get(detection_lows, array.size(detection_lows) - 1)
        LiquidityPool bullPool = LiquidityPool.new(
             id              = f_generate_id(),
             pType           = PoolType.BULLISH,
             state           = LifecycleState.FORMED,
             price           = topLow,
             barCreated      = bar_index - inp_lookback,
             lastTouchBar    = bar_index - inp_lookback,
             touchCount      = 0,
             confidence      = 50.0,
             sessionCreated  = currentSession,
             isSwept         = false,
             visual          = na
         )
        array.push(candidates, bullPool)
        array.pop(detection_lows)
         
    candidates

// =========================================================================
// PHASE 2: REGISTRY
// =========================================================================
var LiquidityPool[] registry = array.new<LiquidityPool>(0)

f_registry_add(LiquidityPool pool) =>
    bool exists = false
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            if p.id == pool.id or (f_is_equal(p.price, pool.price) and p.pType == pool.pType)
                exists := true
                p.lastTouchBar := pool.lastTouchBar
                p.touchCount   := p.touchCount + 1
                if not na(p.visual)
                    label.set_xy(p.visual, bar_index, p.price)
                    label.set_text(p.visual, "Pool: " + f_format_price(p.price) + " (Touches: " + str.tostring(p.touchCount) + ")")
                break
                
    if not exists
        pool.visual := label.new(bar_index, pool.price, "Pool: " + f_format_price(pool.price) + " (Touches: " + str.tostring(pool.touchCount) + ")", color=color.blue, style=label.style_label_down)
        array.push(registry, pool)
        
f_registry_lookup(int id) =>
    LiquidityPool foundPool = na
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            if p.id == id
                foundPool := p
                break
    foundPool

f_registry_maintain() =>
    while array.size(registry) > inp_max_pools
        LiquidityPool oldPool = array.shift(registry)
        if not na(oldPool.visual)
            label.delete(oldPool.visual)

// =========================================================================
// PHASE 3: LIFECYCLE MANAGER
// =========================================================================
f_lifecycle_update() =>
    if array.size(registry) > 0
        for i = 0 to array.size(registry) - 1
            LiquidityPool p = array.get(registry, i)
            
            if p.state == LifecycleState.INVALIDATED or p.state == LifecycleState.EXPIRED
                if not na(p.visual)
                    label.set_text(p.visual, "Price: " + f_format_price(p.price) + "\nState: " + f_state_to_string(p.state) + "\nTouches: " + str.tostring(p.touchCount))
                continue
                
            if p.state == LifecycleState.FORMED and bar_index > p.barCreated
                p.state := LifecycleState.ACTIVE
                
            if bar_index - p.lastTouchBar > EXPIRATION_BARS and p.state != LifecycleState.SWEPT
                p.state := LifecycleState.EXPIRED
                if not na(p.visual)
                    label.set_color(p.visual, color.gray)
                continue
                
            bool isTouched = false
            bool isSwept = false
            bool isInvalidated = false
            
            if p.pType == PoolType.BULLISH
                isTouched := low <= p.price
                isSwept := low < p.price and close > p.price
                isInvalidated := close < p.price
            else if p.pType == PoolType.BEARISH
                isTouched := high >= p.price
                isSwept := high > p.price and close < p.price
                isInvalidated := close > p.price
                
            if isInvalidated
                p.state := LifecycleState.INVALIDATED
                if not na(p.visual)
                    label.set_color(p.visual, color.red)
            else if isSwept and p.state != LifecycleState.SWEPT
                p.state := LifecycleState.SWEPT
                p.isSwept := true
                if not na(p.visual)
                    label.set_color(p.visual, color.orange)
            else if isTouched and p.state == LifecycleState.ACTIVE
                p.state := LifecycleState.REINFORCED
                p.lastTouchBar := bar_index
                p.touchCount := p.touchCount + 1
                if not na(p.visual)
                    label.set_color(p.visual, color.purple)
            
            if not na(p.visual)
                label.set_xy(p.visual, bar_index, p.price)
                label.set_text(p.visual, "Price: " + f_format_price(p.price) + "\nState: " + f_state_to_string(p.state) + "\nTouches: " + str.tostring(p.touchCount))

