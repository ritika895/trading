// Enforce max visualization items: delete oldest when limit exceeded
f_enforceVisualizationLimit() =>
    vizSize = array.size(g_vizItems)
    while vizSize > i_maxVisualizationItems
        if array.size(g_vizItems) > 0
            oldest = array.shift(g_vizItems)
            if oldest.itemType == 0 and not na(oldest.lbl)
                label.delete(oldest.lbl)
            else if oldest.itemType == 1 and not na(oldest.ln)
                line.delete(oldest.ln)
        vizSize := array.size(g_vizItems)

viz_renderPivots(DetectionContext ctx) =>
    if i_showPivotLabels
        if ctx.hasPivotHigh
            lbl = label.new(ctx.pivotHighBar, ctx.pivotHighPrice, "PH: " + str.tostring(math.round(ctx.pivotHighPrice, 2)),
                 style = label.style_label_down, color = color.new(color.red, 30), textcolor = color.white,
                 size = i_labelSize == "tiny" ? size.tiny : (i_labelSize == "small" ? size.small : size.normal))
            if not na(lbl)
                vizItem = VizItem.new(0, lbl, na)
                array.push(g_vizItems, vizItem)
        if ctx.hasPivotLow
            lbl = label.new(ctx.pivotLowBar, ctx.pivotLowPrice, "PL: " + str.tostring(math.round(ctx.pivotLowPrice, 2)),
                 style = label.style_label_up, color = color.new(color.lime, 30), textcolor = color.white,
                 size = i_labelSize == "tiny" ? size.tiny : (i_labelSize == "small" ? size.small : size.normal))
            if not na(lbl)
                vizItem = VizItem.new(0, lbl, na)
                array.push(g_vizItems, vizItem)
    f_enforceVisualizationLimit()

viz_renderSwingLines() =>
    if i_showSwingLines
        candSize = array.size(g_swingCandidatesThisBar)
        if candSize > 0
            for i = 0 to candSize - 1
                if i >= 0 and i < candSize
                    cand = array.get(g_swingCandidatesThisBar, i)
                    if cand.poolType == PoolType.swing_high
                        // Draw red horizontal line for swing high
                        ln = line.new(cand.detectedBar, cand.priceLevel, bar_index, cand.priceLevel,
                             color = color.new(color.red, 50), width = 1, style = line.style_dashed, extend = extend.right)
                        if not na(ln)
                            vizItem = VizItem.new(1, na, ln)
                            array.push(g_vizItems, vizItem)
                    else if cand.poolType == PoolType.swing_low
                        // Draw green horizontal line for swing low
                        ln = line.new(cand.detectedBar, cand.priceLevel, bar_index, cand.priceLevel,
                             color = color.new(color.lime, 50), width = 1, style = line.style_dashed, extend = extend.right)
                        if not na(ln)
                            vizItem = VizItem.new(1, na, ln)
                            array.push(g_vizItems, vizItem)
    f_enforceVisualizationLimit()

// =====================================================================================================================
// MAIN ORCHESTRATION — Detection Layer + Replacement Engine + Registry + Lifecycle Manager + Reinforcement
// Top-level execution: ONLY place where global variables are modified
// =====================================================================================================================

// Build detection context on every bar
ctx = f_buildDetectionContext()

// Process only on confirmed bars
if barstate.isconfirmed
    // Run detectors (no global modifications except array.push to detection results)
    detect_equalHighsLows(ctx)
    detect_singleSwing(ctx)
    detect_trendlineLiquidity(ctx)
    
    // ===============================
    // REPLACEMENT ENGINE — TOP-LEVEL
    // Process all candidates through replacement engine (pure function, no globals modified)
    // ===============================
    replacementResults = replacement_processCandidates()
    
    // ===============================
    // UPDATE REPLACEMENT ENGINE COUNTERS — TOP-LEVEL ONLY
    // This is the ONLY place where replacement engine globals are modified
    // Iterate using indexed access to retrieve results and create records
    // ===============================
    candidatesThisBarCount = array.size(g_swingCandidatesThisBar)
    if candidatesThisBarCount > 0
        g_candidatesProcessed := g_candidatesProcessed + candidatesThisBarCount
        
        resultsSize = array.size(replacementResults)
        if resultsSize > 0 and resultsSize == candidatesThisBarCount
            for i = 0 to resultsSize - 1
                if i >= 0 and i < resultsSize
                    result = array.get(replacementResults, i)
                    
                    if result.accept
                        g_candidatesAccepted := g_candidatesAccepted + 1
                        // Record acceptance in history
                        record = ReplacementRecord.new(i, ReplacementDecision.ignored, -1)
                        array.push(g_replacementHistory, record)
                    else
                        g_candidatesRejected := g_candidatesRejected + 1
                        // Record rejection in history
                        record = ReplacementRecord.new(i, result.decision, result.conflictPoolID)
                        array.push(g_replacementHistory, record)
    
    // ===============================
    // REGISTRY PROCESSING — TOP-LEVEL ONLY
    // This is the ONLY place g_nextPoolID is modified
    // Only add candidates that passed replacement engine
    // ===============================
    if candidatesThisBarCount > 0
        resultsSize = array.size(replacementResults)
        if resultsSize > 0 and resultsSize == candidatesThisBarCount
            for i = 0 to resultsSize - 1
                if i >= 0 and i < resultsSize and i < candidatesThisBarCount
                    result = array.get(replacementResults, i)
                    
                    if result.accept
                        cand = array.get(g_swingCandidatesThisBar, i)
                        
                        // If decision is 'replaced', find and remove the conflicting pool from registry
                        if result.decision == ReplacementDecision.replaced and result.conflictPoolID != -1
                            regSize = array.size(g_registry)
                            if regSize > 0
                                for j = 0 to regSize - 1
                                    pool = array.get(g_registry, j)
                                    if pool.poolID == result.conflictPoolID
                                        array.remove(g_registry, j)
                                        break
                        
                        // 1. Read current poolID
                        currentPoolID = g_nextPoolID
                        // 2. Convert candidate to LiquidityPool (pure function, no globals)
                        pool = f_convertToLiquidityPool(cand, currentPoolID)
                        // 3. Push into Registry
                        array.push(g_registry, pool)
                        // 4. Increment pool ID counter
                        g_nextPoolID := g_nextPoolID + 1
    
    // ===============================
    // LIFECYCLE MANAGER — TOP-LEVEL
    // Process state transitions for all pools
    // ===============================
    lifecycle_processAllPools()
    
    // ===============================
    // REINFORCEMENT ENGINE — TOP-LEVEL ORCHESTRATION
    // 1. Call pure detection function (no globals modified inside)
    // 2. Apply returned events to registry and update global counters
    // ===============================
    reinforcementEvents = reinforcement_detectRevisits()
    
    eventsSize = array.size(reinforcementEvents)
    if eventsSize > 0
        for i = 0 to eventsSize - 1
            if i >= 0 and i < eventsSize
                event = array.get(reinforcementEvents, i)
                
                // Apply event to registry pool
                if event.poolIndex >= 0 and event.poolIndex < array.size(g_registry)
                    pool = array.get(g_registry, event.poolIndex)
                    pool.reinforcementCount := event.newReinforcementCount
                    pool.confidence := event.newConfidence
                    pool.state := event.newState
                    array.set(g_registry, event.poolIndex, pool)
                    
                    // Update global counters (TOP-LEVEL ONLY)
                    g_totalReinforcements := g_totalReinforcements + 1
                    if event.isNewlyReinforced
                        g_reinforcedPools := g_reinforcedPools + 1
    
    // Visualize output
    viz_renderPivots(ctx)
    viz_renderSwingLines()
    
    // Clear this-bar candidates for next bar
    array.clear(g_swingCandidatesThisBar)

// =====================================================================================================================
// STATUS TABLE — Detection + Registry + Lifecycle + Replacement + Confidence + Reinforcement statistics
// =====================================================================================================================

var table g_statusTable = na

if barstate.islast
    if na(g_statusTable)
        g_statusTable := table.new(position.top_right, 2, 24, border_width = 1)
    
    if not na(g_statusTable)
        totalCandidates = array.size(g_swingCandidatesAllTime)
        registrySize = array.size(g_registry)
        highestPoolID = registry_getHighestPoolID()
        hasDuplicates = registry_checkDuplicateIDs()
        registryIntegrityPass = registry_checkIntegrity()
        
        formedCount = lifecycle_countPoolsByState(PoolState.formed)
        activeCount = lifecycle_countPoolsByState(PoolState.active)
        reinforcedCount = lifecycle_countPoolsByState(PoolState.reinforced)
        lifecycleIntegrityPass = lifecycle_checkIntegrity()
        
        replacementIntegrityPass = replacement_checkIntegrity()
        
        // Calculate confidence metrics
        float avgConfidence = 0.0
        float highestConfidence = 0.0
        float lowestConfidence = 100.0
        if registrySize > 0
            float sumConfidence = 0.0
            for i = 0 to registrySize - 1
                pool = array.get(g_registry, i)
                conf = pool.confidence
                sumConfidence := sumConfidence + conf
                if conf > highestConfidence
                    highestConfidence := conf
                if conf < lowestConfidence
                    lowestConfidence := conf
            avgConfidence := sumConfidence / registrySize
        else
            lowestConfidence := 0.0
            
        // Calculate reinforcement metrics
        int highestReinforcement = 0
        float avgReinforcement = 0.0
        if registrySize > 0
            int sumReinforcement = 0
            for i = 0 to registrySize - 1
                pool = array.get(g_registry, i)
                rc = pool.reinforcementCount
                sumReinforcement := sumReinforcement + rc
                if rc > highestReinforcement
                    highestReinforcement := rc
            avgReinforcement := sumReinforcement / registrySize
        
        table.cell(g_statusTable, 0, 0, "DETECTION+REGISTRY+LIFECYCLE+REPLACEMENT", bgcolor = color.new(color.navy, 0), text_color = color.white)
        table.cell(g_statusTable, 1, 0, "", bgcolor = color.new(color.navy, 0))
        
        table.cell(g_statusTable, 0, 1, "Total Candidates", text_color = color.white)
        table.cell(g_statusTable, 1, 1, str.tostring(totalCandidates), text_color = totalCandidates > 0 ? color.green : color.red)
        
        table.cell(g_statusTable, 0, 2, "Candidates Processed", text_color = color.white)
        table.cell(g_statusTable, 1, 2, str.tostring(g_candidatesProcessed), text_color = color.aqua)
        
        table.cell(g_statusTable, 0, 3, "Candidates Accepted", text_color = color.white)
        table.cell(g_statusTable, 1, 3, str.tostring(g_candidatesAccepted), text_color = color.green)
        
        table.cell(g_statusTable, 0, 4, "Candidates Rejected", text_color = color.white)
        table.cell(g_statusTable, 1, 4, str.tostring(g_candidatesRejected), text_color = color.orange)
        
        table.cell(g_statusTable, 0, 5, "Total Pools", text_color = color.white)
        table.cell(g_statusTable, 1, 5, str.tostring(registrySize), text_color = registrySize > 0 ? color.green : color.orange)
        
        table.cell(g_statusTable, 0, 6, "FORMED", text_color = color.white)
        table.cell(g_statusTable, 1, 6, str.tostring(formedCount), text_color = color.aqua)
        
        table.cell(g_statusTable, 0, 7, "ACTIVE", text_color = color.white)
        table.cell(g_statusTable, 1, 7, str.tostring(activeCount), text_color = color.green)
        
        table.cell(g_statusTable, 0, 8, "REINFORCED", text_color = color.white)
        table.cell(g_statusTable, 1, 8, str.tostring(reinforcedCount), text_color = color.purple)
        
        table.cell(g_statusTable, 0, 9, "Registry Integrity", text_color = color.white)
        regIntegrityText = registryIntegrityPass ? "PASS" : "FAIL"
        regIntegrityColor = registryIntegrityPass ? color.green : color.red
        table.cell(g_statusTable, 1, 9, regIntegrityText, text_color = regIntegrityColor)
        
        table.cell(g_statusTable, 0, 10, "Lifecycle Integrity", text_color = color.white)
        lcIntegrityText = lifecycleIntegrityPass ? "PASS" : "FAIL"
        lcIntegrityColor = lifecycleIntegrityPass ? color.green : color.red
        table.cell(g_statusTable, 1, 10, lcIntegrityText, text_color = lcIntegrityColor)
        
        table.cell(g_statusTable, 0, 11, "Replacement Integrity", text_color = color.white)
        replIntegrityText = replacementIntegrityPass ? "PASS" : "FAIL"
        replIntegrityColor = replacementIntegrityPass ? color.green : color.red
        table.cell(g_statusTable, 1, 11, replIntegrityText, text_color = replIntegrityColor)
        
        table.cell(g_statusTable, 0, 12, "Replacement Engine", text_color = color.white)
        table.cell(g_statusTable, 1, 12, i_enableReplacement ? "ENABLED" : "DISABLED", text_color = i_enableReplacement ? color.green : color.orange)
        
        table.cell(g_statusTable, 0, 13, "Confidence Module", text_color = color.white)
        table.cell(g_statusTable, 1, 13, "ENABLED", text_color = color.green)
        
        table.cell(g_statusTable, 0, 14, "Event Bus", text_color = color.white)
        table.cell(g_statusTable, 1, 14, "NO (DISABLED)", text_color = color.orange)
        
        table.cell(g_statusTable, 0, 15, "Session Module", text_color = color.white)
        table.cell(g_statusTable, 1, 15, "NO (DISABLED)", text_color = color.orange)

        table.cell(g_statusTable, 0, 16, "Average Confidence", text_color = color.white)
        table.cell(g_statusTable, 1, 16, str.tostring(math.round(avgConfidence, 2)), text_color = color.aqua)

        table.cell(g_statusTable, 0, 17, "Highest Confidence", text_color = color.white)
        table.cell(g_statusTable, 1, 17, str.tostring(math.round(highestConfidence, 2)), text_color = color.green)

        table.cell(g_statusTable, 0, 18, "Lowest Confidence", text_color = color.white)
        table.cell(g_statusTable, 1, 18, str.tostring(math.round(lowestConfidence, 2)), text_color = color.orange)
        
        table.cell(g_statusTable, 0, 19, "Reinforcement Engine", text_color = color.white)
        table.cell(g_statusTable, 1, 19, i_enableReinforcement ? "ENABLED" : "DISABLED", text_color = i_enableReinforcement ? color.green : color.orange)
        
        table.cell(g_statusTable, 0, 20, "Reinforced Pools", text_color = color.white)
        table.cell(g_statusTable, 1, 20, str.tostring(g_reinforcedPools), text_color = color.aqua)
        
        table.cell(g_statusTable, 0, 21, "Total Reinforcements", text_color = color.white)
        table.cell(g_statusTable, 1, 21, str.tostring(g_totalReinforcements), text_color = color.green)
        
