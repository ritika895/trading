f_convertToLiquidityPool(DetectionCandidate cand, int assignedPoolID) =>
    // Pure function: receives poolID as argument, returns LiquidityPool
    // No global variable modifications
    initialConfidence = confidence_calculate(cand.poolType, 0)
    pool = LiquidityPool.new(
        assignedPoolID,                  // poolID (passed as argument)
        cand.poolType,                   // poolType
        cand.isResistanceSide,           // isResistanceSide
        cand.priceLevel,                 // priceLevel
        cand.detectedBar,                // originBar
        PoolState.formed,                // state: initial state is FORMED
        0,                               // reinforcementCount (placeholder for future use)
        initialConfidence,               // confidence (calculated by Confidence Engine)
        bar_index,                       // formedBar: bar where pool entered FORMED state
        false,                           // hasBeenSwept: initial state is not swept
        -1,                              // sweepBar: no sweep bar yet
        na,                              // sweepPrice: no sweep price yet
        0                                // sweepCount: initial sweep count is zero
    )
    pool

