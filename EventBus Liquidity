// SESSION LIQUIDITY ENGINE — PURE MODULE: tracks institutional session liquidity
// Detects session start/end, records session highs/lows, stores them independently
// NO global variable modifications. Returns SessionProcessResult for top-level to apply.
// =====================================================================================================================

// --- Session Detection ---

session_detect(int startHour, int endHour) =>
    // Determines if the current bar is within the specified session window
    // Uses exchange timezone to determine current hour
    // Returns true if current bar's hour falls within [startHour, endHour)
    currentHour = hour(time, "UTC")
    if startHour <= endHour
        // Session does not cross midnight (e.g., 7 to 15)
        currentHour >= startHour and currentHour < endHour
    else
        // Session crosses midnight (e.g., 22 to 6)
        currentHour >= startHour or currentHour < endHour

// --- Session Update ---

session_update(SessionLevelData sessionData, int startHour, int endHour, bool isEnabled) =>
    // Updates a session's high/low tracking based on current bar
    // Returns the updated SessionLevelData object
    // Handles session start (reset) and session active (track high/low)
    // PURE FUNCTION: read-only on globals, returns modified object
    SessionLevelData updatedData = sessionData
    if isEnabled
        bool inSession = session_detect(startHour, endHour)
        if inSession
            if not sessionData.isActive
                // Session just started: initialize with current bar values
                updatedData.isActive := true
                updatedData.highPrice := high
                updatedData.highBar := bar_index
                updatedData.lowPrice := low
                updatedData.lowBar := bar_index
            else
                // Session ongoing: update high/low if exceeded
                if high > sessionData.highPrice or na(sessionData.highPrice)
                    updatedData.highPrice := high
                    updatedData.highBar := bar_index
                if low < sessionData.lowPrice or na(sessionData.lowPrice)
                    updatedData.lowPrice := low
                    updatedData.lowBar := bar_index
        else
            if sessionData.isActive
                // Session just ended: keep levels but mark inactive
                updatedData.isActive := false
    updatedData

// --- Session Getters ---

session_getHigh(SessionLevelData sessionData) =>
    // Returns the recorded high price for the session
    sessionData.highPrice

session_getLow(SessionLevelData sessionData) =>
    // Returns the recorded low price for the session
    sessionData.lowPrice

// --- Main Session Process ---

session_process(SessionLevelData asianSess, SessionLevelData londonSess, SessionLevelData nySess, SessionLevelData pdSess, SessionLevelData pwSess) =>
    // Processes all session logic: detect, update levels
    // Returns a SessionProcessResult containing all updated session objects and current session name
    // PURE FUNCTION: read-only on globals, returns modified objects
    string currentSession = "None"
    
    SessionLevelData updatedAsian = asianSess
    SessionLevelData updatedLondon = londonSess
    SessionLevelData updatedNY = nySess
    SessionLevelData updatedPD = pdSess
    SessionLevelData updatedPW = pwSess
    
    if i_enableSession
        // 1. Update Previous Day Levels (calculated at the start of a new day)
        bool isNewDay = ta.change(time("D")) != 0
        if isNewDay
            // Shift current daily levels to previous day before resetting
            // Use previous day's built-in functions for accurate historical data
            updatedPD.highPrice := high[1]
            updatedPD.lowPrice := low[1]
            updatedPD.highBar := bar_index - 1
            updatedPD.lowBar := bar_index - 1
            updatedPD.isActive := false
        
        // 2. Update Previous Week Levels (calculated at the start of a new week)
        bool isNewWeek = ta.change(time("W")) != 0
        if isNewWeek
            // Use previous week's built-in functions for accurate historical data
            updatedPW.highPrice := high[1]
            updatedPW.lowPrice := low[1]
            updatedPW.highBar := bar_index - 1
            updatedPW.lowBar := bar_index - 1
            updatedPW.isActive := false
        
        // 3. Update Intraday Session Levels
        updatedAsian := session_update(updatedAsian, i_asianStart, i_asianEnd, i_showAsian)
        updatedLondon := session_update(updatedLondon, i_londonStart, i_londonEnd, i_showLondon)
        updatedNY := session_update(updatedNY, i_newYorkStart, i_newYorkEnd, i_showNewYork)
        
        // 4. Determine current active session for dashboard
        // Priority: New York > London > Asian (if overlapping, latest start takes priority)
        if session_detect(i_newYorkStart, i_newYorkEnd)
            currentSession := "New York"
        else if session_detect(i_londonStart, i_londonEnd)
            currentSession := "London"
        else if session_detect(i_asianStart, i_asianEnd)
            currentSession := "Asian"
        else
            currentSession := "None"
    
    SessionProcessResult.new(updatedAsian, updatedLondon, updatedNY, updatedPD, updatedPW, currentSession)

