//====================================================================
// SWING STRENGTH SYSTEM (Sprint 2.3 - Tier 2: Normalized Scores)
//====================================================================

STRENGTH_LEG_DISTANCE_SATURATION_K = 3.0
STRENGTH_LEG_EFFICIENCY_SATURATION_K = 0.30

STRENGTH_CANDLE_WICK_COMPONENT_WEIGHT = 0.60
STRENGTH_CANDLE_BODY_COMPONENT_WEIGHT = 0.40

normalizeLegDistanceScore(float legDistance, float formationATR) =>
    float ratio = safeDivide(legDistance, formationATR)
    safeDivide(ratio, ratio + STRENGTH_LEG_DISTANCE_SATURATION_K)

normalizeLegEfficiencyScore(float legVelocity, float formationATR) =>
    float ratio = safeDivide(legVelocity, formationATR)
    safeDivide(ratio, ratio + STRENGTH_LEG_EFFICIENCY_SATURATION_K)

normalizeCandleStructureScore(float wickRatio, float bodyRatio) =>
    debugAssert(math.abs((STRENGTH_CANDLE_WICK_COMPONENT_WEIGHT + STRENGTH_CANDLE_BODY_COMPONENT_WEIGHT) - 1.0) < 0.0001, "Candle Structure component weights must sum to 1.0.")

    (wickRatio * STRENGTH_CANDLE_WICK_COMPONENT_WEIGHT) + (bodyRatio * STRENGTH_CANDLE_BODY_COMPONENT_WEIGHT)

//--------------------------------------------------------------------
// TIER 3 - COMPOSITE (Sprint 2.3 - Patch 4)
//--------------------------------------------------------------------

STRENGTH_WEIGHT_LEG_DISTANCE = 0.40
STRENGTH_WEIGHT_LEG_EFFICIENCY = 0.30
STRENGTH_WEIGHT_CANDLE_STRUCTURE = 0.30

computeSwingStrength(bool previousConfirmedExists, float previousConfirmedPrice, int previousConfirmedBar, float thisPrice, int thisBar, float formationATR, float candleRange, float candleBody, float candleExtremeWick) =>
    debugAssert(math.abs((STRENGTH_WEIGHT_LEG_DISTANCE + STRENGTH_WEIGHT_LEG_EFFICIENCY + STRENGTH_WEIGHT_CANDLE_STRUCTURE) - 1.0) < 0.0001, "Swing Strength composite weights must sum to 1.0.")

    float strength = na

    if previousConfirmedExists
        float legDistance = deriveDistance(thisPrice, previousConfirmedPrice)
        int barsElapsed = deriveBarsElapsed(thisBar, previousConfirmedBar)
        float legVelocity = deriveVelocity(legDistance, barsElapsed)

        float wickRatio = deriveWickRejectionRatio(candleExtremeWick, candleRange)
        float bodyRatio = deriveBodyDominanceRatio(candleBody, candleRange)

        float distanceScore = normalizeLegDistanceScore(legDistance, formationATR)
        float efficiencyScore = normalizeLegEfficiencyScore(legVelocity, formationATR)
        float candleScore = normalizeCandleStructureScore(wickRatio, bodyRatio)

        strength := (distanceScore * STRENGTH_WEIGHT_LEG_DISTANCE) + (efficiencyScore * STRENGTH_WEIGHT_LEG_EFFICIENCY) + (candleScore * STRENGTH_WEIGHT_CANDLE_STRUCTURE)

    strength

//====================================================================
// STRUCTURE CLASSIFICATION SYSTEM (Sprint 2.4)
//====================================================================

classifyHighStructure(float currentHigh, float previousHigh, float tolerance) =>
    bool isGenuineNewHigh = not pricesAreEqual(currentHigh, previousHigh, tolerance) and currentHigh > previousHigh
    isGenuineNewHigh ? STRUCTURE_HH : STRUCTURE_LH

classifyLowStructure(float currentLow, float previousLow, float tolerance) =>
    bool isGenuineNewLow = not pricesAreEqual(currentLow, previousLow, tolerance) and currentLow < previousLow
    isGenuineNewLow ? STRUCTURE_LL : STRUCTURE_HL

//====================================================================
// ENGINE API
//====================================================================

startPendingSwing(int swingId, int swingType, float swingPrice, int swingBar) =>
    createSwing(swingId, swingType, swingPrice, swingBar)

confirmPendingSwing(int swingId) =>
    bool updated = updateSwingStatus(swingId, STATUS_CONFIRMED)
    validateDatabaseInDebug("Database integrity failed after confirmation.")
    updated

finalizeConfirmedSwing(int swingId, float atrValue, float previousConfirmedPrice, int previousConfirmedBar, bool previousConfirmedExists) =>
    setSwingATR(swingId, atrValue)

    [_, thisPrice, thisBar, _, _] = getSwing(swingId)
    [formationATR, _] = getSwingFormationATR(swingId)
    [candleRange, _] = getSwingCandleRange(swingId)
    [candleBody, _] = getSwingCandleBody(swingId)
    [candleExtremeWick, _] = getSwingCandleExtremeWick(swingId)

    float strength = computeSwingStrength(previousConfirmedExists, previousConfirmedPrice, previousConfirmedBar, thisPrice, thisBar, formationATR, candleRange, candleBody, candleExtremeWick)

    setSwingStrength(swingId, strength)

replacePendingSwing(int swingId, float replacementPrice, int replacementBar) =>
    int swingIndex = swingIndexFromId(swingId)
    bool exists = swingIndex != NO_INDEX

    if exists
        array.set(swingPrices, swingIndex, replacementPrice)
        array.set(swingBars, swingIndex, replacementBar)
        array.set(swingStatuses, swingIndex, STATUS_PENDING)
        captureFormationSnapshot(swingId)

    validateDatabaseInDebug("Database integrity failed after replacement.")
    exists

rejectPendingSwing(int swingId) =>
    bool exists = swingIndexFromId(swingId) != NO_INDEX
    debugAssert(exists, "Rejected swing references a missing active swing.")
    exists

archivePendingSwing(int swingId) =>
    bool updated = updateSwingStatus(swingId, STATUS_REJECTED)
    validateDatabaseInDebug("Database integrity failed after archive.")
    updated

getActiveSwing(int swingId) =>
    getSwing(swingId)

getLastConfirmedSwing() =>
    databaseLastConfirmedSwing()

getLastConfirmedSwingOfType(int swingType) =>
    databaseLastConfirmedSwingOfType(swingType)

//====================================================================
// MINIMUM LEG FILTER
//====================================================================

legDistance(float transitionSwingPrice, float confirmedSwingPrice) =>
    math.abs(transitionSwingPrice - confirmedSwingPrice)

resolveMinimumLegThreshold() =>
    float threshold = minimumLegPoints

    if thresholdMode == THRESHOLD_MANUAL_OVERRIDE
        threshold := manualLegPoints
    else if thresholdMode == THRESHOLD_ADAPTIVE_ATR
        threshold := na(currentATR) ? minimumLegPoints : math.max(minimumLegPoints, currentATR * atrMultiplier)
    else
        threshold := minimumLegPoints

    threshold

passesMinimumLegFilter(float transitionSwingPrice) =>
    [_, _, lastConfirmedPrice, _, hasConfirmedSwing] = getLastConfirmedSwing()
    bool passesFilter = true

    if hasConfirmedSwing
        float distanceFromLastConfirmed = legDistance(transitionSwingPrice, lastConfirmedPrice)
        float activeThreshold = resolveMinimumLegThreshold()
        passesFilter := distanceFromLastConfirmed >= activeThreshold

    passesFilter

//====================================================================
// REPLACEMENT ENGINE
//====================================================================

var int activePendingSwingType = SWING_NONE
var int activePendingSwingId = NO_SWING_ID
var int activePendingHighSwingId = NO_SWING_ID
var int activePendingLowSwingId = NO_SWING_ID
var int activeTransitionSwingId = NO_SWING_ID

var array<int> currentEventTypes = array.new_int()
var array<int> currentEventSwingTypes = array.new_int()
var array<int> currentEventSwingIds = array.new_int()
var array<float> currentEventPrices = array.new_float()
var array<int> currentEventBars = array.new_int()

var array<int> currentConfirmedSwingTypes = array.new_int()
var array<int> currentConfirmedSwingIds = array.new_int()
var array<float> currentConfirmedSwingPrices = array.new_float()
var array<int> currentConfirmedSwingBars = array.new_int()

resetCurrentBarEvents() =>
    array.clear(currentEventTypes)
    array.clear(currentEventSwingTypes)
    array.clear(currentEventSwingIds)
    array.clear(currentEventPrices)
    array.clear(currentEventBars)
    array.clear(currentConfirmedSwingTypes)
    array.clear(currentConfirmedSwingIds)
    array.clear(currentConfirmedSwingPrices)
    array.clear(currentConfirmedSwingBars)

recordCandidateEvent(int eventType, int swingType, int swingId, float swingPrice, int swingBar) =>
    array.push(currentEventTypes, eventType)
    array.push(currentEventSwingTypes, swingType)
    array.push(currentEventSwingIds, swingId)
    array.push(currentEventPrices, swingPrice)
    array.push(currentEventBars, swingBar)

recordConfirmedSwingEvent(int swingType, int swingId, float swingPrice, int swingBar) =>
    array.push(currentConfirmedSwingTypes, swingType)
    array.push(currentConfirmedSwingIds, swingId)
    array.push(currentConfirmedSwingPrices, swingPrice)
    array.push(currentConfirmedSwingBars, swingBar)

isBetterReplacement(int swingType, float candidatePrice, float activePrice) =>
    swingType == SWING_HIGH ? candidatePrice > activePrice : candidatePrice < activePrice

activateNewPendingSwing(int candidateType, float candidatePrice, int candidateBar, int swingId) =>
    int newSwingId = startPendingSwing(swingId, candidateType, candidatePrice, candidateBar)
    int updatedHighSwingId = candidateType == SWING_HIGH ? newSwingId : activePendingHighSwingId
    int updatedLowSwingId = candidateType == SWING_LOW ? newSwingId : activePendingLowSwingId

    recordCandidateEvent(EVENT_ACCEPTED, candidateType, newSwingId, candidatePrice, candidateBar)

    [candidateType, newSwingId, updatedHighSwingId, updatedLowSwingId]

processSameSideCandidate(int candidateType, float candidatePrice, int candidateBar) =>
    [_, storedPrice, _, _, exists] = getActiveSwing(activePendingSwingId)
    [transitionType, transitionPrice, transitionBar, _, transitionExists] = getSwing(activeTransitionSwingId)

    int updatedActiveType = activePendingSwingType
    int updatedActiveId = activePendingSwingId
    int updatedHighId = activePendingHighSwingId
    int updatedLowId = activePendingLowSwingId
    int updatedTransitionId = activeTransitionSwingId
    bool createdSwingRecord = false

    bool shouldReplace = exists and isBetterReplacement(candidateType, candidatePrice, storedPrice)
    int eventType = shouldReplace ? EVENT_REPLACED : EVENT_REJECTED

    if shouldReplace
        replacePendingSwing(activePendingSwingId, candidatePrice, candidateBar)

        if transitionExists and transitionBar <= candidateBar
            archivePendingSwing(activeTransitionSwingId)
            updatedTransitionId := NO_SWING_ID
        else if transitionExists and passesMinimumLegFilter(transitionPrice)
            [_, _, prevConfirmedPrice, prevConfirmedBar, prevConfirmedExists] = getLastConfirmedSwing()
            bool confirmed = confirmPendingSwing(activePendingSwingId)

            if confirmed
                finalizeConfirmedSwing(activePendingSwingId, currentATR, prevConfirmedPrice, prevConfirmedBar, prevConfirmedExists)
                recordConfirmedSwingEvent(candidateType, activePendingSwingId, candidatePrice, candidateBar)

            updatedActiveType := transitionType
            updatedActiveId := activeTransitionSwingId
            updatedHighId := transitionType == SWING_HIGH ? activeTransitionSwingId : activePendingHighSwingId
            updatedLowId := transitionType == SWING_LOW ? activeTransitionSwingId : activePendingLowSwingId
            updatedTransitionId := NO_SWING_ID
    else
        rejectPendingSwing(activePendingSwingId)

    recordCandidateEvent(eventType, candidateType, activePendingSwingId, candidatePrice, candidateBar)

    [updatedActiveType, updatedActiveId, updatedHighId, updatedLowId, updatedTransitionId, createdSwingRecord]

processOppositeCandidate(int candidateType, float candidatePrice, int candidateBar, int swingId) =>
    [storedType, storedPrice, storedBar, _, exists] = getActiveSwing(activePendingSwingId)
    [transitionType, transitionPrice, transitionBar, _, transitionExists] = getSwing(activeTransitionSwingId)

    int updatedActiveType = activePendingSwingType
    int updatedActiveId = activePendingSwingId
    int updatedHighId = activePendingHighSwingId
    int updatedLowId = activePendingLowSwingId
    int updatedTransitionId = activeTransitionSwingId
    bool createdSwingRecord = false

    int eventType = EVENT_ACCEPTED
    int eventSwingId = swingId

    bool transitionMatchesCandidate = transitionExists and transitionType == candidateType

    if not transitionMatchesCandidate
        if transitionExists
            archivePendingSwing(activeTransitionSwingId)

        int newTransitionId = startPendingSwing(swingId, candidateType, candidatePrice, candidateBar)

        updatedTransitionId := newTransitionId
        transitionType := candidateType
        transitionPrice := candidatePrice
        transitionBar := candidateBar
        transitionExists := true

        eventType := EVENT_ACCEPTED
        eventSwingId := newTransitionId
        createdSwingRecord := true
    else
        eventSwingId := activeTransitionSwingId

        if isBetterReplacement(candidateType, candidatePrice, transitionPrice)
            replacePendingSwing(activeTransitionSwingId, candidatePrice, candidateBar)

            transitionPrice := candidatePrice
            transitionBar := candidateBar
            eventType := EVENT_REPLACED
        else
            eventType := EVENT_REJECTED

    recordCandidateEvent(eventType, candidateType, eventSwingId, candidatePrice, candidateBar)

    bool canConfirmPendingSwing = exists and transitionExists and passesMinimumLegFilter(transitionPrice)

    if canConfirmPendingSwing
        [_, _, prevConfirmedPrice, prevConfirmedBar, prevConfirmedExists] = getLastConfirmedSwing()
        bool confirmed = confirmPendingSwing(activePendingSwingId)

        if confirmed
            finalizeConfirmedSwing(activePendingSwingId, currentATR, prevConfirmedPrice, prevConfirmedBar, prevConfirmedExists)
            recordConfirmedSwingEvent(storedType, activePendingSwingId, storedPrice, storedBar)

        updatedActiveType := transitionType
        updatedActiveId := updatedTransitionId
        updatedHighId := transitionType == SWING_HIGH ? updatedTransitionId : activePendingHighSwingId
        updatedLowId := transitionType == SWING_LOW ? updatedTransitionId : activePendingLowSwingId
        updatedTransitionId := NO_SWING_ID

    [updatedActiveType, updatedActiveId, updatedHighId, updatedLowId, updatedTransitionId, createdSwingRecord]

processCandidate(int candidateType, float candidatePrice, int candidateBar, int swingId) =>
    int updatedActiveType = activePendingSwingType
    int updatedActiveId = activePendingSwingId
    int updatedHighId = activePendingHighSwingId
    int updatedLowId = activePendingLowSwingId
    int updatedTransitionId = activeTransitionSwingId
    bool createdSwingRecord = false

    if activePendingSwingType == SWING_NONE
        [firstType, firstId, firstHighId, firstLowId] = activateNewPendingSwing(candidateType, candidatePrice, candidateBar, swingId)

        updatedActiveType := firstType
        updatedActiveId := firstId
        updatedHighId := firstHighId
        updatedLowId := firstLowId
        updatedTransitionId := NO_SWING_ID
        createdSwingRecord := true

    else if activePendingSwingType == candidateType
        [sameType, sameId, sameHighId, sameLowId, sameTransitionId, sameCreated] = processSameSideCandidate(candidateType, candidatePrice, candidateBar)

        updatedActiveType := sameType
        updatedActiveId := sameId
        updatedHighId := sameHighId
        updatedLowId := sameLowId
        updatedTransitionId := sameTransitionId
        createdSwingRecord := sameCreated

    else
        [oppositeType, oppositeId, oppositeHighId, oppositeLowId, oppositeTransitionId, oppositeCreated] = processOppositeCandidate(candidateType, candidatePrice, candidateBar, swingId)

        updatedActiveType := oppositeType
        updatedActiveId := oppositeId
        updatedHighId := oppositeHighId
        updatedLowId := oppositeLowId
        updatedTransitionId := oppositeTransitionId
        createdSwingRecord := oppositeCreated

    validateDatabaseInDebug("Database integrity failed after candidate processing.")

    [updatedActiveType, updatedActiveId, updatedHighId, updatedLowId, updatedTransitionId, createdSwingRecord]

resetCurrentBarEvents()

if hasCandidateHigh
    [updatedTypeHigh, updatedIdHigh, updatedHighSwingIdHigh, updatedLowSwingIdHigh, updatedTransitionIdHigh, createdHighSwing] = processCandidate(SWING_HIGH, candidateHighPrice, candidateHighBar, nextSwingId)

    activePendingSwingType := updatedTypeHigh
    activePendingSwingId := updatedIdHigh
    activePendingHighSwingId := updatedHighSwingIdHigh
    activePendingLowSwingId := updatedLowSwingIdHigh
    activeTransitionSwingId := updatedTransitionIdHigh

    if createdHighSwing
        nextSwingId += 1

if hasCandidateLow
    [updatedTypeLow, updatedIdLow, updatedHighSwingIdLow, updatedLowSwingIdLow, updatedTransitionIdLow, createdLowSwing] = processCandidate(SWING_LOW, candidateLowPrice, candidateLowBar, nextSwingId)

    activePendingSwingType := updatedTypeLow
    activePendingSwingId := updatedIdLow
    activePendingHighSwingId := updatedHighSwingIdLow
    activePendingLowSwingId := updatedLowSwingIdLow
    activeTransitionSwingId := updatedTransitionIdLow

    if createdLowSwing
        nextSwingId += 1

//====================================================================
// VISUALIZATION
//====================================================================

isDeveloperMode() =>
    displayMode == DISPLAY_DEVELOPER

isTestMode() =>
    displayMode == DISPLAY_TEST

drawDeveloperDebugLabel(int eventType, int swingType, int swingId, float swingPrice, int swingBar) =>
    if showDebugLabels and isDeveloperMode()
        string sideText = swingType == SWING_HIGH ? "High" : "Low"
        string eventText = eventType == EVENT_ACCEPTED ? "Accepted" : eventType == EVENT_REPLACED ? "Replaced" : "Rejected"
        string labelText = eventText + " " + sideText + " #" + str.tostring(swingId)
        color labelColor = eventType == EVENT_ACCEPTED ? acceptedColor : eventType == EVENT_REPLACED ? replacedColor : rejectedColor

        label.new(swingBar, swingPrice, labelText, xloc = xloc.bar_index, yloc = yloc.price, style = swingType == SWING_HIGH ? label.style_label_down : label.style_label_up, color = labelColor, textcolor = color.white, size = size.tiny)

drawConfirmedSwingLabel(int swingType, int swingId, float swingPrice, int swingBar) =>
    if showConfirmedSwings and (isDeveloperMode() or isTestMode())
        string swingText = swingType == SWING_HIGH ? "H" : "L"
        string labelText = isDeveloperMode() ? swingText + " #" + str.tostring(swingId) : swingText

        label.new(swingBar, swingPrice, labelText, xloc = xloc.bar_index, yloc = yloc.price, style = swingType == SWING_HIGH ? label.style_label_down : label.style_label_up, color = color.new(color.blue, 0), textcolor = color.white, size = size.small)

int confirmedCount = array.size(currentConfirmedSwingIds)

if confirmedCount > 0
    for index = 0 to confirmedCount - 1
        int confirmedType = array.get(currentConfirmedSwingTypes, index)
        int confirmedId = array.get(currentConfirmedSwingIds, index)
        float confirmedPrice = array.get(currentConfirmedSwingPrices, index)
        int confirmedBar = array.get(currentConfirmedSwingBars, index)

        drawConfirmedSwingLabel(confirmedType, confirmedId, confirmedPrice, confirmedBar)

int eventCount = array.size(currentEventTypes)

if eventCount > 0
    for index = 0 to eventCount - 1
        int eventType = array.get(currentEventTypes, index)
        int eventSwingType = array.get(currentEventSwingTypes, index)
        int eventSwingId = array.get(currentEventSwingIds, index)
        float eventPrice = array.get(currentEventPrices, index)
        int eventBar = array.get(currentEventBars, index)

        drawDeveloperDebugLabel(eventType, eventSwingType, eventSwingId, eventPrice, eventBar)

plotshape(hasCandidateHigh and isDeveloperMode(), title = "Candidate High", style = shape.triangledown, location = location.abovebar, color = color.new(color.red, 75), size = size.tiny, offset = -pivotRightBars)

plotshape(hasCandidateLow and isDeveloperMode(), title = "Candidate Low", style = shape.triangleup, location = location.belowbar, color = color.new(color.green, 75), size = size.tiny, offset = -pivotRightBars)
