// swingIndexFromId - resolves a swingId to its storage index.
//
// ---------------------------------------------------------------
// ARCHITECTURAL DEPENDENCY - DO NOT REMOVE THIS NOTE
// ---------------------------------------------------------------
// This implementation depends on the project's database contracts:
// sequential, gapless ID allocation and append-only storage. If a
// future architectural change introduces ID reuse, compaction,
// archival relocation, or externally generated IDs, the arithmetic
// implementation of swingIndexFromId() must be replaced with an
// appropriate lookup implementation (e.g. a cached index, a map, or
// a restored linear search), and every call site re-audited against
// the new allocation/storage model.
//
// Given those two contracts hold: createSwing() is the sole function
// that ever appends to swingIds (verified: no other function in this
// file calls array.push/insert/remove/sort/shift on swingIds), and
// every push consumes nextSwingId's current value with an increment
// matched 1:1 to each push (verified across every branch of
// processCandidate(), processSameSideCandidate(), and
// processOppositeCandidate()). Therefore swingId N is always stored
// at index N-1, and existence reduces to a bounds check.
// ---------------------------------------------------------------
swingIndexFromId(int swingId) =>
    int size = array.size(swingIds)
    int candidateIndex = swingId - 1
    bool exists = swingId > 0 and candidateIndex < size

    exists ? candidateIndex : NO_INDEX

isValidSwingType(int swingType) =>
    swingType == SWING_HIGH or swingType == SWING_LOW

isValidSwingStatus(int statusValue) =>
    statusValue == STATUS_PENDING or statusValue == STATUS_CONFIRMED or statusValue == STATUS_REPLACED or statusValue == STATUS_REJECTED

isValidStructureLabel(int structureLabel) =>
    structureLabel == STRUCTURE_NONE or structureLabel == STRUCTURE_HH or structureLabel == STRUCTURE_HL or structureLabel == STRUCTURE_LH or structureLabel == STRUCTURE_LL

isValidStructureLabelForType(int structureLabel, int swingType) =>
    bool valid = true

    if structureLabel == STRUCTURE_HH or structureLabel == STRUCTURE_LH
        valid := swingType == SWING_HIGH
    else if structureLabel == STRUCTURE_HL or structureLabel == STRUCTURE_LL
        valid := swingType == SWING_LOW

    valid

isValidBreakType(int breakType) =>
    breakType == BREAK_NONE or breakType == BREAK_BOS or breakType == BREAK_CHOCH

isValidImportance(int importanceValue) =>
    importanceValue == IMPORTANCE_MINOR or importanceValue == IMPORTANCE_INTERMEDIATE or importanceValue == IMPORTANCE_MAJOR

debugAssert(bool condition, string message) =>
    if showDebugLabels and not condition
        runtime.error(message)

// databaseHasDuplicateIds() REMOVED (prior optimization pass):
// duplicate swing IDs are impossible by construction given
// monotonic, gapless, non-reused ID issuance (see the architectural
// dependency note on swingIndexFromId() above). This O(n^2) runtime
