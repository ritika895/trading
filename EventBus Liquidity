// REINFORCEMENT ENGINE — PURE MODULE: detects price revisits and calculates reinforcement data
// NO global variable modifications. Returns array of ReinforcementEvent for top-level to apply.
// =====================================================================================================================

reinforcement_findPoolIndex(float priceLevel, bool isResistanceSide) =>
    // Finds the first active pool matching the price level and side
    // PURE FUNCTION: read-only, no global modifications
    foundIndex = -1
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            pool = array.get(g_registry, i)
            if pool.isResistanceSide == isResistanceSide
                priceDiff = math.abs(pool.priceLevel - priceLevel)
                if priceDiff <= i_reinforcementTolerance
                    foundIndex := i
                    break
    foundIndex

reinforcement_calculateEvent(int poolIndex) =>
    // Given a pool index, calculate what the reinforcement event would look like
    // PURE FUNCTION: read-only, returns ReinforcementEvent or na if invalid index
    ReinforcementEvent event = na
    registrySize = array.size(g_registry)
    if poolIndex >= 0 and poolIndex < registrySize
        pool = array.get(g_registry, poolIndex)
        isNewlyReinforced = (pool.reinforcementCount == 0)
        newCount = pool.reinforcementCount + 1
        newConf = confidence_calculate(pool.poolType, newCount)
        newState = pool.state
        if pool.state == PoolState.active
            newState := PoolState.reinforced
        event := ReinforcementEvent.new(poolIndex, isNewlyReinforced, newCount, newConf, newState)
    event

reinforcement_detectRevisits() =>
    // Checks current bar high/low against existing pools
    // PURE FUNCTION: returns array of ReinforcementEvent objects, NO global modifications
    events = array.new<ReinforcementEvent>()
    if i_enableReinforcement
        registrySize = array.size(g_registry)
        if registrySize > 0
            float currentHigh = high
            float currentLow = low
            
            // Check high prices against resistance pools
            highIndex = reinforcement_findPoolIndex(currentHigh, true)
            if highIndex != -1
                event = reinforcement_calculateEvent(highIndex)
                if not na(event)
                    array.push(events, event)
                
            // Check low prices against support pools
            lowIndex = reinforcement_findPoolIndex(currentLow, false)
            if lowIndex != -1
                event = reinforcement_calculateEvent(lowIndex)
                if not na(event)
                    array.push(events, event)
    
    events

