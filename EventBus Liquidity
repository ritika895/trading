// =====================================================================================================================

// --- Event Publish ---

event_publish(array<EngineEvent> currentQueue, int nextID, EventType eType, int poolId, string sessId, float ePrice, string eDirection, float eConfidence, string eDesc) =>
    // Creates an event and adds it to the queue
    // Returns an EventBusResult containing the updated queue, generated event, and next ID
    // PURE FUNCTION: read-only on globals, returns modified object
    EngineEvent newEvent = EngineEvent.new(nextID, eType, poolId, sessId, bar_index, ePrice, eDirection, eConfidence, eDesc, false)
    array<EngineEvent> updatedQueue = array.new<EngineEvent>()
    queueSize = array.size(currentQueue)
    if queueSize > 0
        for i = 0 to queueSize - 1
            if i >= 0 and i < queueSize
                array.push(updatedQueue, array.get(currentQueue, i))
    array.push(updatedQueue, newEvent)
    
    // Enforce max queue size: remove oldest if limit exceeded
    while array.size(updatedQueue) > i_maxEventQueueSize
        array.shift(updatedQueue)
    
    EventBusResult.new(updatedQueue, 0, 0, newEvent)

// --- Event Subscribe (Query) ---

event_subscribe(array<EngineEvent> currentQueue, EventType targetType) =>
    // Retrieves all events of a specific type from the queue
    // PURE FUNCTION: read-only
    array<EngineEvent> filteredEvents = array.new<EngineEvent>()
    queueSize = array.size(currentQueue)
    if queueSize > 0
        for i = 0 to queueSize - 1
            if i >= 0 and i < queueSize
                event = array.get(currentQueue, i)
                if event.eventType == targetType
                    array.push(filteredEvents, event)
    filteredEvents

// --- Event Process ---

event_process(array<EngineEvent> currentQueue) =>
    // Marks all unprocessed events in the queue as processed
    // Returns an EventBusResult containing the updated queue and the count of newly processed events
    // PURE FUNCTION: read-only on globals, returns modified object
    array<EngineEvent> updatedQueue = array.new<EngineEvent>()
    int processedCount = 0
    queueSize = array.size(currentQueue)
    if queueSize > 0
        for i = 0 to queueSize - 1
            if i >= 0 and i < queueSize
                event = array.get(currentQueue, i)
                if not event.isProcessed
                    event.isProcessed := true
                    processedCount := processedCount + 1
                array.push(updatedQueue, event)
    EventBusResult.new(updatedQueue, 0, processedCount, na)

// --- Event Get Latest ---

event_getLatest(array<EngineEvent> currentQueue) =>
    // Retrieves the most recent event from the queue
    // PURE FUNCTION: read-only
    EngineEvent latestEvent = na
    queueSize = array.size(currentQueue)
    if queueSize > 0
        latestEvent := array.get(currentQueue, queueSize - 1)
    latestEvent

// --- Event Clear Processed ---

event_clearProcessed(array<EngineEvent> currentQueue) =>
    // Removes all processed events from the queue to free up space
    // Returns the cleaned queue
    // PURE FUNCTION: read-only on globals, returns modified object
    array<EngineEvent> cleanedQueue = array.new<EngineEvent>()
    queueSize = array.size(currentQueue)
    if queueSize > 0
        for i = 0 to queueSize - 1
            if i >= 0 and i < queueSize
                event = array.get(currentQueue, i)
                if not event.isProcessed
                    array.push(cleanedQueue, event)
    cleanedQueue

