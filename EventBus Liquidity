registry_getHighestPoolID() =>
    highestID = 0
    registrySize = array.size(g_registry)
    if registrySize > 0
        for i = 0 to registrySize - 1
            pool = array.get(g_registry, i)
            if pool.poolID > highestID
                highestID := pool.poolID
    highestID

registry_checkIntegrity() =>
    // Registry Integrity: Size == Highest Pool ID (IDs are sequential, nothing deleted)
    registrySize = array.size(g_registry)
    highestID = registry_getHighestPoolID()
    registrySize == highestID

